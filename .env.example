# Copy this to .env and fill in your real values
# Get these from: GitHub repo -> Settings -> Secrets and variables -> Actions

ANTHROPIC_API_KEY=sk-ant-...
LINKEDIN_ACCESS_TOKEN=AQ...
LINKEDIN_AUTHOR_URN=urn:li:person:...
LINKEDIN_PERSON_ID=...

# Ads reporting (ad_analytics.py) — needs r_ads + r_ads_reporting scopes, which the
# organic posting token above does not carry. Falls back to LINKEDIN_ACCESS_TOKEN.
LINKEDIN_ADS_ACCESS_TOKEN=AQ...
# Marketing API version, YYYYMM. LinkedIn sunsets old versions — bump when yours ages out.
LINKEDIN_API_VERSION=202606
