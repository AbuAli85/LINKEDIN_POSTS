# Anthropic API key — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# LinkedIn OAuth — see LINKEDIN_SETUP.md for full instructions
LINKEDIN_ACCESS_TOKEN=AQXxxxxx
LINKEDIN_AUTHOR_URN=urn:li:person:xxxxxxxxxx

# Optional: override which pillar to post (leave blank to auto-pick by weekday)
# Values: leadership | ai | marketing
FORCE_PILLAR=

# Optional: workflow mode. Default is safe draft generation.
# Values: draft | generate_draft | publish_draft | publish_now
POST_MODE=draft

# Required only when POST_MODE=publish_draft
PUBLISH_DRAFT_PATH=

# Required only when POST_MODE=post_reply
ENGAGEMENT_PATH=

# Safety confirmation required only when POST_MODE=publish_now
CONFIRM_PUBLISH_NOW=false

# Optional: dry-run mode for publish_now — generate but don't publish
DRY_RUN=false

# Optional: notify when a new draft is ready for review
# Set to false to disable all draft notifications
NOTIFY_ON_DRAFT=true
# Resend email notifications: requires RESEND_API_KEY and recipient email
RESEND_API_KEY=
NOTIFY_EMAIL=
# Optional verified sender. If blank, Resend's onboarding sender is used.
NOTIFY_FROM=
# Optional webhook endpoint for Slack, Make, Zapier, Discord, or custom automations
NOTIFY_WEBHOOK_URL=
# Optional dashboard URL override. Defaults to GitHub Pages URL when running in Actions.
DASHBOARD_URL=
