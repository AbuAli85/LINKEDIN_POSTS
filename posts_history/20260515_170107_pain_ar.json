{
  "pillar": "pain_ar",
  "topic": "\u0644\u0645\u0627\u0630\u0627 \u064a\u063a\u0627\u062f\u0631 \u0623\u0641\u0636\u0644 \u0645\u0648\u0638\u0641\u064a\u0643 \u062d\u064a\u0646 \u062a\u0643\u0648\u0646 \u0639\u0645\u0644\u064a\u0627\u062a \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u0641\u0648\u0636\u0648\u064a\u0629\u061f",
  "format": "\u0627\u0641\u062a\u062d \u0628\u0633\u0624\u0627\u0644 \u064a\u064f\u062c\u0628\u0631 \u0627\u0644\u0642\u0627\u0631\u0626 \u0639\u0644\u0649 \u062d\u0633\u0627\u0628 \u0625\u062c\u0627\u0628\u062a\u0647 \u0627\u0644\u062e\u0627\u0635\u0629 \u2014 \u0627\u0644\u0648\u0642\u062a \u0627\u0644\u0636\u0627\u0626\u0639\u060c \u0627\u0644\u0645\u0627\u0644 \u0627\u0644\u0645\u0647\u062f\u0631\u060c \u0627\u0644\u0645\u062e\u0627\u0637\u0631 \u0627\u0644\u0645\u062d\u0645\u0648\u0644\u0629",
  "language": "ar",
  "post": "\u0643\u0645 \u0633\u0627\u0639\u0629 \u0623\u0645\u0636\u064a\u062a \u0647\u0630\u0627 \u0627\u0644\u0623\u0633\u0628\u0648\u0639 \u0641\u064a \u0627\u0644\u0628\u062d\u062b \u0639\u0646 \u0639\u0642\u062f \u0645\u0648\u0638\u0641 \u0641\u064a \u0631\u0633\u0627\u0626\u0644 \u0642\u062f\u064a\u0645\u0629\u061f\n\n\u0644\u0623\u0646 \u0647\u0630\u0627 \u0644\u064a\u0633 \u0645\u062c\u0631\u062f \u0625\u0632\u0639\u0627\u062c.\n\u0647\u0630\u0627 \u0647\u0648 \u0627\u0644\u0633\u0628\u0628 \u0627\u0644\u0641\u0639\u0644\u064a \u0627\u0644\u0630\u064a \u064a\u062c\u0639\u0644 \u0623\u0641\u0636\u0644 \u0645\u0648\u0638\u0641\u064a\u0643 \u064a\u0641\u0643\u0631\u0648\u0646 \u0641\u064a \u0627\u0644\u0645\u063a\u0627\u062f\u0631\u0629.\n\n\u0627\u0644\u0645\u0648\u0638\u0641 \u0627\u0644\u0645\u062d\u062a\u0631\u0641 \u0644\u0627 \u064a\u063a\u0627\u062f\u0631 \u0628\u0633\u0628\u0628 \u0627\u0644\u0631\u0627\u062a\u0628 \u0641\u0642\u0637.\n\u064a\u063a\u0627\u062f\u0631 \u062d\u064a\u0646 \u064a\u0631\u0649 \u0623\u0646 \u0627\u0644\u0634\u0631\u0643\u0629 \u0644\u0627 \u062a\u0639\u0631\u0641 \u062a\u0627\u0631\u064a\u062e \u0627\u0646\u062a\u0647\u0627\u0621 \u0625\u062c\u0627\u0632\u062a\u0647\u060c \u0648\u0644\u0627 \u0645\u0648\u0639\u062f \u062a\u062c\u062f\u064a\u062f \u062a\u0635\u0631\u064a\u062d\u0647\u060c \u0648\u0644\u0627 \u0625\u0630\u0627 \u0648\u0635\u0644 \u0631\u0627\u062a\u0628\u0647 \u0628\u0634\u0643\u0644 \u0635\u062d\u064a\u062d \u0647\u0630\u0627 \u0627\u0644\u0634\u0647\u0631.\n\n\u0627\u0644\u0641\u0648\u0636\u0649 \u0644\u0627 \u062a\u064f\u062e\u064a\u0641 \u0627\u0644\u0645\u0648\u0638\u0641 \u0627\u0644\u0636\u0639\u064a\u0641 \u2014 \u0628\u0644 \u062a\u064f\u0646\u0641\u0651\u0631 \u0627\u0644\u0645\u0648\u0638\u0641 \u0627\u0644\u0630\u0643\u064a.\n\n\u0627\u0644\u0630\u064a \u064a\u0639\u0631\u0641 \u0642\u064a\u0645\u062a\u0647 \u064a\u0628\u062d\u062b \u0639\u0646 \u0628\u064a\u0626\u0629 \u0645\u0646\u0638\u0645\u0629.\n\u0648\u0627\u0644\u0630\u064a \u064a\u0635\u0628\u0631 \u0639\u0644\u0649 \u0627\u0644\u0641\u0648\u0636\u0649... \u064a\u0635\u0628\u0631 \u0644\u0623\u0646\u0647 \u0644\u0627 \u064a\u062c\u062f \u0628\u062f\u064a\u0644\u0627\u064b \u0627\u0644\u0622\u0646.\n\n\u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u0644\u064a\u0633\u062a \u0641\u064a \u0646\u0648\u0627\u064a\u0627\u0643.\n\u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u0641\u064a \u0627\u0644\u0623\u062f\u0648\u0627\u062a: \u062c\u062f\u0627\u0648\u0644 Excel \u0645\u062a\u0646\u0627\u062b\u0631\u0629\u060c \u0645\u062c\u0645\u0648\u0639\u0627\u062a \u0648\u0627\u062a\u0633\u0627\u0628 \u0644\u0637\u0644\u0628\u0627\u062a \u0627\u0644\u0625\u062c\u0627\u0632\u0629\u060c \u0631\u0648\u0627\u062a\u0628 \u062a\u064f\u062d\u0633\u0628 \u064a\u062f\u0648\u064a\u0627\u064b \u0643\u0644 \u0634\u0647\u0631 \u0645\u0646 \u062c\u062f\u064a\u062f.\n\nSmartPro Hub \u064a\u062c\u0645\u0639 \u0627\u0644\u0631\u0648\u0627\u062a\u0628 \u0648\u0627\u0644\u0625\u062c\u0627\u0632\u0627\u062a \u0648\u0627\u0644\u0627\u0645\u062a\u062b\u0627\u0644 \u0648\u0627\u0644\u0639\u0642\u0648\u062f \u0641\u064a \u0646\u0638\u0627\u0645 \u0648\u0627\u062d\u062f \u2014 \u0645\u0635\u0645\u0645 \u0644\u0634\u0631\u0643\u0627\u062a \u0639\u064f\u0645\u0627\u0646 \u0645\u0646 \u0661\u0660 \u0625\u0644\u0649 \u0662\u0660\u0660 \u0645\u0648\u0638\u0641\u060c \u0628\u062f\u0621\u0627\u064b \u0645\u0646 \u0661\u0662 \u0631\u064a\u0627\u0644\u0627\u064b \u0634\u0647\u0631\u064a\u0627\u064b.\n\n\u0627\u0644\u0645\u0648\u0638\u0641 \u0627\u0644\u062c\u064a\u062f \u0627\u0644\u0630\u064a \u062e\u0633\u0631\u062a\u0647 \u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u0645\u0627\u0636\u064a \u2014 \u0647\u0644 \u0643\u0627\u0646 \u064a\u0645\u0643\u0646 \u0625\u0628\u0642\u0627\u0624\u0647 \u0644\u0648 \u0643\u0627\u0646\u062a \u0627\u0644\u0639\u0645\u0644\u064a\u0627\u062a \u0623\u0648\u0636\u062d\u061f\n\nBook a 20-minute demo at www.thesmartpro.io \u20