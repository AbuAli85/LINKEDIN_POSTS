{
  "pillar": "sanad_pro_ar",
  "topic": "\u0627\u0644\u062a\u062d\u0648\u0644 \u0627\u0644\u0631\u0642\u0645\u064a \u0627\u0644\u062d\u0643\u0648\u0645\u064a \u0641\u064a \u0639\u064f\u0645\u0627\u0646 \u064a\u062a\u0633\u0627\u0631\u0639. \u0645\u0643\u0627\u062a\u0628 \u0633\u0646\u062f \u0627\u0644\u062a\u064a \u062a\u062a\u0635\u0644 \u0628\u0647 \u0645\u0628\u0643\u0631\u0627\u064b \u0633\u062a\u0645\u062a\u0644\u0643 \u0633\u0648\u0642 \u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0627\u0645\u062a\u062b\u0627\u0644.",
  "format": "\u0627\u0641\u062a\u062d \u0628\u0633\u0624\u0627\u0644 \u064a\u064f\u062c\u0628\u0631 \u0627\u0644\u0642\u0627\u0631\u0626 \u0639\u0644\u0649 \u062d\u0633\u0627\u0628 \u0625\u062c\u0627\u0628\u062a\u0647: \u0643\u0645 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u062a\u062a\u0627\u0628\u0639\u0647 \u0627\u0644\u0622\u0646\u060c \u0648\u0623\u064a\u0646 \u0628\u0627\u0644\u0636\u0628\u0637 \u064a\u0648\u062c\u062f \u0647\u0630\u0627 \u0627\u0644\u0633\u062c\u0644\u061f",
  "language": "ar",
  "post": "\u0643\u0645 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u062a\u062a\u0627\u0628\u0639\u0647 \u0627\u0644\u0622\u0646\u061f \u0648\u0623\u064a\u0646 \u0628\u0627\u0644\u0636\u0628\u0637 \u064a\u0648\u062c\u062f \u0627\u0644\u0633\u062c\u0644\u061f\n\n\u0625\u0630\u0627 \u0627\u062d\u062a\u062c\u062a \u062b\u0644\u0627\u062b \u062b\u0648\u0627\u0646\u064d \u0644\u0644\u0625\u062c\u0627\u0628\u0629 \u2014 \u0641\u0627\u0644\u062c\u0648\u0627\u0628 \u0645\u0648\u062c\u0648\u062f \u0641\u064a \u0645\u0643\u0627\u0646 \u0645\u0627 \u0628\u064a\u0646 \u0645\u062c\u0645\u0648\u0639\u0629 \u0648\u0627\u062a\u0633\u0627\u0628 \u0648\u0645\u0644\u0641 \u0625\u0643\u0633\u0644 \u0648\u0648\u0631\u0642\u0629 \u0639\u0644\u0649 \u0627\u0644\u0645\u0643\u062a\u0628.\n\n\u0647\u0630\u0627 \u0644\u064a\u0633 \u0627\u0646\u062a\u0642\u0627\u062f\u0627\u064b. \u0647\u0630\u0627 \u0648\u0627\u0642\u0639 \u0669\u0662\u0664 \u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0641\u064a \u0639\u064f\u0645\u0627\u0646 \u0627\u0644\u064a\u0648\u0645.\n\n\u0664\u0660 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644\u060c \u0661\u0665 \u062a\u0623\u0634\u064a\u0631\u0629\u060c \u0668 \u0645\u0639\u0627\u0645\u0644\u0627\u062a \u0648\u0632\u0627\u0631\u0629 \u0639\u0645\u0644 \u2014 \u0644\u0639\u0634\u0631\u064a\u0646 \u0634\u0631\u0643\u0629 \u0639\u0645\u064a\u0644 \u0645\u062e\u062a\u0644\u0641\u0629. \u0643\u0644 \u0648\u0627\u062d\u062f\u0629 \u0628\u062a\u0648\u0627\u0631\u064a\u062e \u0627\u0646\u062a\u0647\u0627\u0621 \u0645\u062e\u062a\u0644\u0641\u0629\u060c \u0648\u0645\u062a\u0637\u0644\u0628\u0627\u062a \u0645\u062e\u062a\u0644\u0641\u0629\u060c \u0648\u0645\u062f\u064a\u0631 HR \u064a\u064f\u0631\u0627\u0633\u0644\u0643 \u0643\u0644 \u064a\u0648\u0645 \u064a\u0633\u0623\u0644 \"\u0648\u064a\u0646 \u0648\u0635\u0644\u062a \u0627\u0644\u0645\u0639\u0627\u0645\u0644\u0629\u061f\"\n\n\u0648\u0627\u0644\u062a\u062d\u0648\u0644 \u0627\u0644\u0631\u0642\u0645\u064a \u0627\u0644\u062d\u0643\u0648\u0645\u064a \u064a\u062a\u0633\u0627\u0631\u0639. \u0646\u0638\u0627\u0645 \u0627\u0644\u0639\u0645\u0644 \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a\u060c \u0627\u0644\u0628\u0648\u0627\u0628\u0627\u062a \u0627\u0644\u0645\u0648\u062d\u062f\u0629\u060c \u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0630\u0627\u062a\u064a\u0629 \u2014 \u0643\u0644 \u0647\u0630\u0627 \u064a\u0639\u0646\u064a \u0623\u0646 \u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0627\u0644\u0630\u064a \u064a\u062a\u0635\u0644 \u0628\u0627\u0644\u0631\u0642\u0645\u0646\u0629 \u0645\u0628\u0643\u0631\u0627\u064b \u0633\u064a\u064f\u0635\u0628\u062d \u0627\u0644\u0645\u0631\u062c\u0639 \u0627\u0644\u0645\u0648\u062b\u0648\u0642 \u0644\u0639\u0645\u0644\u0627\u0626\u0647. \u0648\u0627\u0644\u0630\u064a \u064a\u062a\u0623\u062e\u0631 \u0633\u064a\u062c\u062f \u0646\u0641\u0633\u0647 \u064a\u0634\u0631\u062d \u0644\u0644\u0639\u0645\u064a\u0644 \u0645\u0639\u0644\u0648\u0645\u0629 \u0648\u062c\u062f\u0647\u0627 \u0628\u0646\u0641\u0633\u0647 \u0639\u0644\u0649 \u0627\u0644\u0625\u0646\u062a\u0631\u0646\u062a.\n\n\u0627\u0644\u0633\u0624\u0627\u0644 \u0644\u064a\u0633 \"\u0647\u0644 \u062a\u062a\u062d\u0648\u0644 \u0631\u0642\u0645\u064a\u0627\u064b\u061f\"\n\u0627\u0644\u0633\u0624\u0627\u0644: \"\u0645\u0646 \u0633\u064a\u0633\u0628\u0642 \u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u0633\u0648\u0642\u061f\"\n\n\u0645\u0646 \u064a\u064f\u062f\u064a\u0631 \u0627\u0644\u064a\u0648\u0645 \u0623\u0643\u062b\u0631 \u0645\u0646 \u0661\u0660 \u0639\u0645\u0644\u0627\u0621 \u2014 \u0643\u064a\u0641 \u062a\u062a\u0627\u0628\u0639 \u062a\u0648\u0627\u0631\u064a\u062e \u0627\u0644\u0627\u0646\u062a\u0647\u0627\u0621 \u0642\u0628\u0644 \u0623\u0646 \u062a\u0641\u0627\u062c\u0626\u0643\u061f\n\n\u062c\u0631\u0651\u0628 \u0645\u0633\u0627\u0639\u062f \u0633\u0646\u062f \u0627\u0644\u0630\u0643\u064a \u0645\u062c\u0627\u0646\u0627\u064b \u2014 \u0625\u062c\u0627\u0