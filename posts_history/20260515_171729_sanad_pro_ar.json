{
  "pillar": "sanad_pro_ar",
  "topic": "\u0625\u062f\u062e\u0627\u0644 \u0635\u0648\u062a\u064a \u0628\u0627\u0644\u0644\u0647\u062c\u0629 \u0627\u0644\u0639\u064f\u0645\u0627\u0646\u064a\u0629. \u0628\u062d\u062b \u0641\u0648\u0631\u064a \u0641\u064a \u0627\u0644\u0631\u0633\u0648\u0645 \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629. \u0645\u0637\u0627\u0628\u0642\u0629 \u0645\u0639 \u0623\u0642\u0631\u0628 \u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0645\u0631\u062e\u0635. \u0639\u0631\u0636 \u0633\u0639\u0631 \u0643\u0627\u0645\u0644. \u0645\u062c\u0627\u0646\u064a. \u0628\u062f\u0648\u0646 \u062a\u0633\u062c\u064a\u0644. \u0647\u0630\u0627 \u0645\u0633\u0627\u0639\u062f \u0633\u0646\u062f \u0627\u0644\u0630\u0643\u064a \u0639\u0644\u0649 www.thesmartpro.io/sanad/assistant",
  "format": "\u0627\u0641\u062a\u062d \u0628\u0633\u0624\u0627\u0644 \u064a\u064f\u062c\u0628\u0631 \u0627\u0644\u0642\u0627\u0631\u0626 \u0639\u0644\u0649 \u062d\u0633\u0627\u0628 \u0625\u062c\u0627\u0628\u062a\u0647: \u0643\u0645 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u062a\u062a\u0627\u0628\u0639\u0647 \u0627\u0644\u0622\u0646\u060c \u0648\u0623\u064a\u0646 \u0628\u0627\u0644\u0636\u0628\u0637 \u064a\u0648\u062c\u062f \u0647\u0630\u0627 \u0627\u0644\u0633\u062c\u0644\u061f",
  "language": "ar",
  "post": "\u0643\u0645 \u0631\u0633\u0648\u0645 \u062a\u0635\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0644\u0645\u0647\u0646\u062f\u0633 \u0645\u062f\u0646\u064a \u0627\u0644\u0622\u0646\u061f\n\n\u0627\u0633\u0623\u0644 \u0646\u0641\u0633\u0643 \u0643\u064a\u0641 \u0633\u062a\u0631\u062f\u0651 \u0639\u0644\u0649 \u0639\u0645\u064a\u0644 \u064a\u0631\u0633\u0644 \u0647\u0630\u0627 \u0627\u0644\u0633\u0624\u0627\u0644 \u0627\u0644\u0633\u0627\u0639\u0629 \u0627\u0644\u062a\u0627\u0633\u0639\u0629 \u0635\u0628\u0627\u062d\u0627\u064b \u2014 \u0642\u0628\u0644 \u0623\u0646 \u062a\u0641\u062a\u062d \u0623\u064a \u0645\u0648\u0642\u0639\u060c \u0648\u0642\u0628\u0644 \u0623\u0646 \u062a\u062a\u0630\u0643\u0631 \u0623\u064a\u0646 \u062d\u0641\u0638\u062a \u0622\u062e\u0631 \u0643\u062a\u0627\u0644\u0648\u062c \u0631\u0633\u0648\u0645.\n\n\u0645\u0639\u0638\u0645\u0646\u0627 \u064a\u064f\u0645\u0636\u064a \u062f\u0642\u0627\u0626\u0642 \u0641\u064a \u0627\u0644\u0628\u062d\u062b. \u0648\u0623\u062d\u064a\u0627\u0646\u0627\u064b \u064a\u0631\u0633\u0644 \u0631\u0642\u0645\u0627\u064b \u0645\u0646 \u0627\u0644\u0630\u0627\u0643\u0631\u0629 \u2014 \u0648\u0647\u0648 \u062e\u0637\u0623.\n\n\u0627\u0644\u0631\u0633\u0648\u0645 \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629 \u062a\u062a\u063a\u064a\u0631. \u0648\u0627\u0644\u0639\u0645\u064a\u0644 \u0644\u0627 \u064a\u0639\u0631\u0641 \u0630\u0644\u0643. \u0623\u0646\u062a \u0645\u0646 \u064a\u062a\u062d\u0645\u0644 \u0627\u0644\u0641\u0631\u0642.\n\n\u0645\u0633\u0627\u0639\u062f \u0633\u0646\u062f \u0627\u0644\u0630\u0643\u064a \u064a\u0631\u062f \u0639\u0644\u0649 \u0647\u0630\u0627 \u0627\u0644\u0633\u0624\u0627\u0644 \u0641\u0648\u0631\u0627\u064b \u2014 \u0628\u0627\u0644\u0635\u0648\u062a\u060c \u0628\u0627\u0644\u0644\u0647\u062c\u0629 \u0627\u0644\u0639\u064f\u0645\u0627\u0646\u064a\u0629\u060c \u0628\u0627\u0644\u0631\u0642\u0645 \u0627\u0644\u0631\u0633\u0645\u064a \u0627\u0644\u062d\u0627\u0644\u064a. \u062a\u0643\u0644\u0651\u0645 \u0641\u064a\u0647 \u0645\u0628\u0627\u0634\u0631\u0629\u060c \u062f\u0648\u0646 \u062a\u0633\u062c\u064a\u0644 \u062f\u062e\u0648\u0644\u060c \u062f\u0648\u0646 \u0627\u0646\u062a\u0638\u0627\u0631.\n\n\u064a\u0628\u062d\u062b \u0641\u064a \u0627\u0644\u0631\u0633\u0648\u0645 \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629 \u0627\u0644\u0645\u0639\u062a\u0645\u062f\u0629\u060c \u0648\u064a\u0639\u0631\u0636 \u0639\u0631\u0636 \u0633\u0639\u0631 \u0643\u0627\u0645\u0644\u0627\u064b \u064a\u0634\u0645\u0644 \u0631\u0633\u0648\u0645 \u0627\u0644\u062c\u0647\u0629 \u0648\u0631\u0633\u0648\u0645 \u0627\u0644\u0645\u0643\u062a\u0628\u060c \u0648\u064a\u064f\u0637\u0627\u0628\u0642 \u0645\u0639 \u0623\u0642\u0631\u0628 \u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0645\u0631\u062e\u0635 \u0641\u064a \u0645\u062d\u0627\u0641\u0638\u062a\u0643.\n\n\u0645\u062c\u0627\u0646\u064a. \u0627\u0644\u0622\u0646.\n\n\u062c\u0631\u0651\u0628 \u0645\u0633\u0627\u0639\u062f \u0633\u0646\u062f \u0627\u0644\u0630\u0643\u064a \u0645\u062c\u0627\u0646\u0627\u064b \u2014 \u0625\u062c\u0627\u0628\u0627\u062a \u0641\u0648\u0631\u064a\u0629 \u0639\u0646 \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0648\u0627\u0644\u062a\u0623\u0634\u064a\u0631\u0627\u062a \u0648\u0627\u0644\u0631\u0633\u0648\u0645 \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629: www.thesmartpro.io/sanad/assistant\n\n\u0643\u0645 \u0645\u0631\u0629 \u0641\u064a \u0627\u0644\u0623\u0633\u0628\u0648\u0639 \u062a\u064f\u0631\u0633\u0644 \u0631\u0642\u0645\u0627\u064b \u0645\u0646 \u0627\u0644\u0630\u0627\u0643\u0631\u0629 \u0648\u0623\u0646\u062a \u063a\u064a\u0631 \u0645\u062a\u0623\u0643\u062f \u0645\u0646\u0647 \u062a\u0645\u0627\u0645\u0627\u064b\u061f\n\n#\u0633\u0646\u062f\n#\u062e\u062f\u0645\u0627\u062a_PRO\n#\u062a\u0635\u0627\u0631\u064a\u062d_\u0627\u0644\u0639\u0645\u0644\n#\u0645\u0643\u0627\u062a\u0628_\u0633\u0646\u062f_\u0639\u064f\u0645\u0627\u0646\n#SmartPro