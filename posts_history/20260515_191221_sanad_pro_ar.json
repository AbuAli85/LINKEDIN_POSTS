{
  "pillar": "sanad_pro_ar",
  "topic": "\u0643\u062a\u0627\u0644\u0648\u062c \u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0630\u064a \u064a\u064f\u0635\u062f\u0631 \u0627\u0644\u0641\u0627\u062a\u0648\u0631\u0629 \u062a\u0644\u0642\u0627\u0626\u064a\u0627\u064b \u062d\u064a\u0646 \u062a\u064f\u063a\u0644\u0642 \u0627\u0644\u0642\u0636\u064a\u0629 \u2014 \u0645\u0627 \u0627\u0644\u0630\u064a \u064a\u0641\u0639\u0644\u0647 \u0647\u0630\u0627 \u0644\u0644\u062a\u062f\u0641\u0642 \u0627\u0644\u0646\u0642\u062f\u064a",
  "format": "\u0627\u0641\u062a\u062d \u0628\u0633\u0624\u0627\u0644 \u064a\u064f\u062c\u0628\u0631 \u0627\u0644\u0642\u0627\u0631\u0626 \u0639\u0644\u0649 \u062d\u0633\u0627\u0628 \u0625\u062c\u0627\u0628\u062a\u0647: \u0643\u0645 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u062a\u062a\u0627\u0628\u0639\u0647 \u0627\u0644\u0622\u0646\u060c \u0648\u0623\u064a\u0646 \u0628\u0627\u0644\u0636\u0628\u0637 \u064a\u0648\u062c\u062f \u0647\u0630\u0627 \u0627\u0644\u0633\u062c\u0644\u061f",
  "language": "ar",
  "post": "\u0643\u0645 \u0641\u0627\u062a\u0648\u0631\u0629 \u0623\u0635\u062f\u0631\u062a\u0647\u0627 \u0647\u0630\u0627 \u0627\u0644\u0634\u0647\u0631 \u0628\u0639\u062f \u0625\u063a\u0644\u0627\u0642 \u0627\u0644\u0642\u0636\u064a\u0629 \u0645\u0628\u0627\u0634\u0631\u0629 \u2014 \u0648\u0643\u0645 \u0645\u0646\u0647\u0627 \u062a\u0630\u0643\u0651\u0631\u062a\u0647\u0627 \u0628\u0639\u062f \u064a\u0648\u0645\u064a\u0646\u061f\n\n\u0647\u0630\u0627 \u0627\u0644\u0633\u0624\u0627\u0644 \u064a\u0639\u0631\u0641 \u0625\u062c\u0627\u0628\u062a\u0647 \u0643\u0644 \u0645\u0646 \u064a\u064f\u062f\u064a\u0631 \u0623\u0643\u062b\u0631 \u0645\u0646 \u0639\u0634\u0631\u0629 \u0639\u0645\u0644\u0627\u0621.\n\n\u062a\u064f\u0646\u062c\u0632 \u062a\u0635\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644. \u062a\u064f\u062e\u0628\u0631 \u0627\u0644\u0639\u0645\u064a\u0644. \u062a\u0646\u062a\u0642\u0644 \u0644\u0644\u0642\u0636\u064a\u0629 \u0627\u0644\u062a\u0627\u0644\u064a\u0629.\n\u0627\u0644\u0641\u0627\u062a\u0648\u0631\u0629\u061f \u062a\u062c\u0644\u0633 \u0641\u064a \u0627\u0644\u0630\u0627\u0643\u0631\u0629 \u0623\u0648 \u0641\u064a \u0645\u0644\u0627\u062d\u0638\u0629 \u0639\u0644\u0649 \u0627\u0644\u0647\u0627\u062a\u0641 \u2014 \u062d\u062a\u0649 \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0634\u0647\u0631 \u062d\u064a\u0646 \u062a\u062c\u0644\u0633 \u0644\u062a\u062a\u0630\u0643\u0631 \u0645\u0627\u0630\u0627 \u0623\u0646\u062c\u0632\u062a \u0628\u0627\u0644\u0636\u0628\u0637.\n\n\u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u0644\u064a\u0633\u062a \u0627\u0644\u0646\u0633\u064a\u0627\u0646. \u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u0623\u0646 \u0643\u062a\u0627\u0644\u0648\u062c \u062e\u062f\u0645\u0627\u062a\u0643 \u063a\u064a\u0631 \u0645\u0631\u0628\u0648\u0637 \u0628\u0633\u064a\u0631 \u0627\u0644\u0639\u0645\u0644.\n\n\u062d\u064a\u0646 \u062a\u064f\u063a\u0644\u0642 \u0627\u0644\u0642\u0636\u064a\u0629 \u0641\u064a SmartPro Hub\u060c \u062a\u064f\u0635\u062f\u0631 \u0627\u0644\u0641\u0627\u062a\u0648\u0631\u0629 \u062a\u0644\u0642\u0627\u0626\u064a\u0627\u064b \u0628\u0627\u0644\u062e\u062f\u0645\u0629\u060c \u0627\u0644\u0633\u0639\u0631\u060c \u0648\u0627\u0633\u0645 \u0627\u0644\u0639\u0645\u064a\u0644.\n\u0644\u0627 \u062a\u0631\u062c\u0639 \u0644\u0644\u0630\u0627\u0643\u0631\u0629. \u0644\u0627 \u062a\u062c\u0645\u0639 \u0623\u0631\u0642\u0627\u0645\u0627\u064b \u0645\u0646 \u0648\u0627\u062a\u0633\u0627\u0628 \u0641\u064a \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0634\u0647\u0631.\n\n\u0627\u0644\u062a\u062f\u0641\u0642 \u0627\u0644\u0646\u0642\u062f\u064a \u0644\u0627 \u064a\u062a\u062d\u0633\u0646 \u0644\u0623\u0646\u0643 \u062a\u0639\u0645\u0644 \u0623\u0643\u062b\u0631 \u2014 \u064a\u062a\u062d\u0633\u0646 \u062d\u064a\u0646 \u0644\u0627 \u062a\u0633\u0642\u0637 \u0623\u064a \u062e\u062f\u0645\u0629 \u0645\u0646\u062c\u0632\u0629 \u0628\u064a\u0646 \u0641\u0627\u062a\u0648\u0631\u062a\u064a\u0646.\n\n\u0645\u0627 \u0627\u0644\u062e\u062f\u0645\u0629 \u0627\u0644\u062a\u064a \u0623\u0646\u062c\u0632\u062a\u0647\u0627 \u0627\u0644\u0634\u0647\u0631 \u0627\u0644\u0645\u0627\u0636\u064a \u0648\u0644\u0645 \u062a\u064f\u0641\u0648\u062a\u0631 \u0639\u0644\u064a\u0647\u0627\u061f\n\n\u062c\u0631\u0651\u0628 \u0645\u0633\u0627\u0639\u062f \u0633\u0646\u062f \u0627\u0644\u0630\u0643\u064a \u0645\u062c\u0627\u0646\u0627\u064b \u2014 \u0625\u062c\u0627\u0628\u0627\u062a \u0641\u0648\u0631\u064a\u0629 \u0639\u0646 \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0648\u0627\u0644\u062a\u0623\u0634\u064a\u0631\u0627\u062a \u0648\u0627\u0644\u0631\u0633\u0648\u0645 \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629: www.thesmartpro.io/sanad/assistant\n\n#\u0645\u0643\u0627\u062a\u0628_\u0633\u0646\u062f\n#\u062e\u062f\u0645\u0627\u062a_PRO\n#\u0648\u0632\u0627\u0631\u0629_\u0627\u0644\u0639\u0645\u0644\n#\u062a\u0635\u0627\u0631\u064a\u062d_\u0627\u0644\u0639\u0645\u0644\n#SmartPro_Hub",
