{
  "pillar": "pain_ar",
  "topic": "\u062a\u062a\u0628\u0639 \u0668\u0660 \u0631\u0635\u064a\u062f \u0625\u062c\u0627\u0632\u0629 \u0641\u064a \u062c\u062f\u0648\u0644 \u0625\u0643\u0633\u0644 \u0645\u0634\u062a\u0631\u0643 \u2014 \u0634\u062e\u0635 \u0645\u0627 \u064a\u062d\u0635\u0644 \u062f\u0627\u0626\u0645\u0627\u064b \u0639\u0644\u0649 \u0627\u0644\u0631\u0642\u0645 \u0627\u0644\u062e\u0627\u0637\u0626",
  "format": "\u0633\u0650\u0631\u0652 \u0639\u0628\u0631 \u064a\u0648\u0645 \u0643\u0627\u0645\u0644 \u0644\u0641\u0631\u064a\u0642 HR \u064a\u064f\u062f\u064a\u0631 \u0647\u0630\u0627 \u064a\u062f\u0648\u064a\u0627\u064b \u2014 \u0623\u0638\u0647\u0631 \u0643\u0644 \u062e\u0637\u0648\u0629 \u0645\u0643\u0633\u0648\u0631\u0629 \u0628\u0627\u0644\u062a\u0633\u0644\u0633\u0644",
  "language": "ar",
  "post": "\u0627\u0644\u0633\u0627\u0639\u0629 \u0627\u0644\u062b\u0627\u0645\u0646\u0629 \u0648\u0627\u0644\u0646\u0635\u0641 \u0635\u0628\u0627\u062d\u0627\u064b. \u0645\u0648\u0638\u0641 \u064a\u0631\u0633\u0644 \u0637\u0644\u0628 \u0625\u062c\u0627\u0632\u0629 \u0639\u0644\u0649 \u0648\u0627\u062a\u0633\u0627\u0628. \u0645\u062f\u064a\u0631 \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u064a\u0641\u062a\u062d \u0645\u0644\u0641 \u0627\u0644\u0625\u0643\u0633\u0644 \u0627\u0644\u0645\u0634\u062a\u0631\u0643. \u064a\u0628\u062d\u062b \u0639\u0646 \u0627\u0644\u0627\u0633\u0645 \u0641\u064a \u0668\u0660 \u0635\u0641. \u064a\u062c\u062f \u0627\u0644\u0631\u0642\u0645. \u064a\u064f\u062f\u0648\u0651\u0646\u0647 \u0641\u064a \u0645\u0643\u0627\u0646 \u0622\u062e\u0631. \u062b\u0645 \u064a\u0643\u062a\u0634\u0641 \u0623\u0646 \u0632\u0645\u064a\u0644\u0647 \u0639\u062f\u0651\u0644 \u0627\u0644\u0645\u0644\u0641 \u0642\u0628\u0644 \u0639\u0634\u0631\u064a\u0646 \u062f\u0642\u064a\u0642\u0629.\n\n\u064a\u0628\u062f\u0623 \u0645\u0646 \u0627\u0644\u0623\u0648\u0644.\n\n\u0647\u0630\u0627 \u0644\u064a\u0633 \u062e\u0637\u0623 \u0623\u062d\u062f. \u0627\u0644\u0625\u0643\u0633\u0644 \u0644\u0645 \u064a\u064f\u0635\u0645\u064e\u0651\u0645 \u0644\u0647\u0630\u0627. \u0644\u0643\u0646 \u0644\u0627 \u0623\u062d\u062f \u0648\u062c\u062f \u0648\u0642\u062a\u0627\u064b \u0644\u064a\u0628\u062d\u062b \u0639\u0646 \u0628\u062f\u064a\u0644.\n\n\u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u0644\u0627 \u062a\u0642\u0641 \u0647\u0646\u0627. \u0641\u064a \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0634\u0647\u0631\u060c \u064a\u0639\u062a\u0645\u062f \u0627\u0644\u0631\u0627\u062a\u0628 \u0639\u0644\u0649 \u0631\u0635\u064a\u062f \u0627\u0644\u0625\u062c\u0627\u0632\u0629. \u0627\u0644\u0631\u0635\u064a\u062f \u0645\u0623\u062e\u0648\u0630 \u0645\u0646 \u0645\u0644\u0641 \u0639\u062f\u0651\u0644\u0647 \u062b\u0644\u0627\u062b\u0629 \u0623\u0634\u062e\u0627\u0635 \u0645\u062e\u062a\u0644\u0641\u0648\u0646 \u0641\u064a \u062b\u0644\u0627\u062b\u0629 \u0623\u0648\u0642\u0627\u062a \u0645\u062e\u062a\u0644\u0641\u0629. \u0623\u062d\u062f\u0647\u0645 \u0646\u0633\u064a \u064a\u062d\u0641\u0638. \u0623\u062d\u062f\u0647\u0645 \u0623\u0636\u0627\u0641 \u0635\u0641 \u0641\u064a \u0627\u0644\u0645\u0643\u0627\u0646 \u0627\u0644\u062e\u0637\u0623. \u0648\u0623\u062d\u062f\u0647\u0645 \u0623\u0631\u0633\u0644 \u0627\u0644\u0625\u0635\u062f\u0627\u0631 \u0627\u0644\u0642\u062f\u064a\u0645 \u0628\u0627\u0644\u062e\u0637\u0623.\n\n\u0627\u0644\u0645\u0648\u0638\u0641 \u064a\u0631\u0649 \u0631\u0642\u0645\u0627\u064b. \u0635\u0627\u062d\u0628 \u0627\u0644\u0639\u0645\u0644 \u064a\u0631\u0649 \u0631\u0642\u0645\u0627\u064b \u0622\u062e\u0631. \u0648\u0627\u0644\u0627\u062b\u0646\u0627\u0646 \u064a\u0624\u0645\u0646\u0627\u0646 \u0623\u0646 \u0631\u0642\u0645\u0647\u0645\u0627 \u0635\u062d\u064a\u062d.\n\n\u062b\u0645\u0627\u0646\u064a \u0634\u0631\u0643\u0627\u062a \u0645\u0646 \u0639\u0634\u0631 \u062a\u062f\u064a\u0631 \u0625\u062c\u0627\u0632\u0627\u062a\u0647\u0627 \u0647\u0643\u0630\u0627 \u2014 \u062c\u062f\u0648\u0644 \u0645\u0634\u062a\u0631\u0643\u060c \u0644\u0627 \u0633\u062c\u0644 \u0645\u0648\u062d\u062f\u060c \u0644\u0627 \u062a\u0627\u0631\u064a\u062e \u062a\u0639\u062f\u064a\u0644 \u0648\u0627\u0636\u062d.\n\n\u0627\u0644\u062b\u0642\u0629 \u062a\u064f\u0628\u0646\u0649 \u0639\u0644\u0649 \u0645\u0639\u0644\u0648\u0645\u0629 \u0648\u0627\u062d\u062f\u0629 \u0635\u062d\u064a\u062d\u0629 \u0641\u064a \u0627\u0644\u0648\u0642\u062a \u0627\u0644\u0635\u062d\u064a\u062d. \u0644\u0627 \u0639\u0644\u0649 \u0645\u0644\u0641 \u064a\u0641\u062a\u062d\u0647 \u062e\u0645\u0633\u0629 \u0623\u0634\u062e\u0627\u0635 \u0641\u064a \u0622\u0646\u064d \u0648\u0627\u062d\u062f.\n\n\u0643\u064a\u0641 \u062a\u064f\u062f\u064a\u0631 \u0631\u0635\u064a\u062f \u0627\u0644\u0625\u062c\u0627\u0632\u0627\u062a \u0639\u0646\u062f\u0643 \u0627\u0644\u0622\u0646\u061f \u0648\u0643\u0645 \u0645\u0631\u0629 \u0627\u062e\u062a\u0644\u0641\u062a \u0627\u0644\u0623\u0631\u0642\u0627\u0645\u061f\n\n\u0627\u062d\u062c\u0632 \u0639\u0631\u0636\u0627\u064b \u062a\u062c\u0631\u064a\u0628\u064a\u0627\u064b \u0645\u062c\u0627\u0646\u064a\u0627\u064b \u0645\u062f\u062a\u0647 \u0662\u0660 \u062f\u0642\u064a\u0642\u0629 \u0639\u0644\u0649 www.thesmartpro.io \u2014 \u0623\u0648 \u0631\u0627\u0633\u0644\u0646\u0627 \u0639\u0644\u0649 \u0648\u0627\u062a\u0633\u0627\u0628 +96879665522 \u0644\u0645\u0634\u0627\u0647\u062f\u0629 SmartPro \u0645\u0628\u0627\u0634\u0631\u0629.\n\n#\u0625\u062f\u0627\u0631\u0629_\u0627\u0644\u0645\u0648\u0627\u0631\u062f_\u0627\u0644\u0628\u0634\u0631\u064a\u0629\n#\u0639\u0645\u0644\u064a\u0627\u062a_\u0627\u0644\u0623\u0639\u0645\u0627\u0644_\u0639\u064f\u0645\u0627\u0646\n#\u0625\u062f\u0627\u0631\u0629_\u0627\u0644\u0631\u0648\u0627\u062a\u0628\n#SmartPro_Hub\n#\u0634\u0631\u0643\u0627\u062a_\u0639\u064f\u0645\u0627\u0646",
