{
  "pillar": "sanad_pro_ar",
  "topic": "\u0644\u0645\u0627\u0630\u0627 \u062a\u062a\u0648\u0642\u0641 \u0645\u0639\u0638\u0645 \u0645\u0643\u0627\u062a\u0628 \u0633\u0646\u062f \u0639\u0646\u062f \u0661\u0665-\u0662\u0660 \u0639\u0645\u064a\u0644\u0627\u064b \u2014 \u0648\u0645\u0627 \u0627\u0644\u0630\u064a \u064a\u064f\u0634\u0643\u0651\u0644 \u0627\u0644\u0633\u0642\u0641 \u0627\u0644\u062a\u0634\u063a\u064a\u0644\u064a\u061f",
  "format": "\u0633\u0650\u0631\u0652 \u0628\u0627\u0644\u062a\u0641\u0635\u064a\u0644 \u0639\u0628\u0631 \u064a\u0648\u0645 \u0643\u0627\u0645\u0644 \u0644\u0645\u062f\u064a\u0631 \u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u064a\u062a\u0627\u0628\u0639 \u0662\u0660+ \u0634\u0631\u0643\u0629 \u0639\u0645\u064a\u0644 \u0628\u062f\u0648\u0646 \u0646\u0638\u0627\u0645 \u2014 \u0643\u0644 \u062e\u0637\u0648\u0629 \u0645\u0624\u0644\u0645\u0629 \u0628\u0627\u0644\u062a\u0633\u0644\u0633\u0644",
  "language": "ar",
  "post": "\u0627\u0644\u0633\u0627\u0639\u0629 \u0668:\u0661\u0665 \u0635\u0628\u0627\u062d\u0627\u064b. \u0641\u062a\u062d\u062a \u0648\u0627\u062a\u0633\u0627\u0628 \u0648\u0644\u0642\u064a\u062a \u0662\u0663 \u0631\u0633\u0627\u0644\u0629 \u0645\u0646 \u0667 \u0634\u0631\u0643\u0627\u062a.\n\n\u0648\u0627\u062d\u062f\u0629 \u062a\u0633\u0623\u0644 \u0639\u0646 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u0642\u064f\u062f\u0650\u0651\u0645 \u0642\u0628\u0644 \u0623\u0633\u0628\u0648\u0639\u064a\u0646.\n\u0648\u0623\u062e\u0631\u0649 \u062a\u0637\u0644\u0628 \u062a\u062d\u062f\u064a\u062b \u0628\u064a\u0627\u0646\u0627\u062a \u0641\u064a \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0639\u0645\u0644.\n\u0648\u062b\u0627\u0644\u062b\u0629 \u0628\u0643\u0644 \u0628\u0633\u0627\u0637\u0629: \"\u0648\u064a\u0646 \u0648\u0635\u0644\u0646\u0627 \u0641\u064a \u0627\u0644\u0641\u064a\u0632\u0627\u061f\"\n\n\u062a\u0641\u062a\u062d \u0645\u0644\u0641 \u0627\u0644\u0625\u0643\u0633\u0644. \u062a\u0628\u062d\u062b. \u062b\u0645 \u062a\u062a\u0630\u0643\u0631 \u2014 \u062d\u062f\u0651\u062b\u062a \u0646\u0633\u062e\u0629 \u062b\u0627\u0646\u064a\u0629 \u0628\u0627\u0644\u0623\u0645\u0633. \u0644\u0643\u0646 \u0627\u0644\u0646\u0633\u062e\u0629 \u0627\u0644\u0623\u0648\u0644\u0649\u061f \u0627\u0644\u0644\u0647 \u0623\u0639\u0644\u0645.\n\n---\n\n\u0642\u0628\u0644 \u0627\u0644\u0639\u0627\u0634\u0631\u0629\u060c \u0627\u0643\u062a\u0634\u0641\u062a \u0623\u0646 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u0644\u0623\u062d\u062f \u0639\u0645\u0644\u0627\u0626\u0643 \u0627\u0646\u062a\u0647\u0649 \u0642\u0628\u0644 \u0661\u0661 \u064a\u0648\u0645\u0627\u064b.\n\u0645\u0627 \u0641\u064a \u062a\u0646\u0628\u064a\u0647. \u0645\u0627 \u0641\u064a \u062a\u0630\u0643\u064a\u0631. \u0631\u0642\u0645 \u0641\u064a \u062e\u0644\u064a\u0629 \u0645\u0627 \u0631\u062c\u0639\u062a \u0644\u0647\u0627.\n\n---\n\n\u0627\u0644\u0633\u0627\u0639\u0629 \u0627\u0644\u062b\u0627\u0646\u064a\u0629\u060c \u0639\u0646\u062f\u0643 \u0627\u062c\u062a\u0645\u0627\u0639 \u0645\u0639 \u0639\u0645\u064a\u0644 \u062c\u062f\u064a\u062f \u064a\u0631\u064a\u062f \u064a\u0642\u0627\u0631\u0646 \u0623\u0633\u0639\u0627\u0631\u0643.\n\u0642\u0636\u064a\u062a \u0662\u0660 \u062f\u0642\u064a\u0642\u0629 \u062a\u062c\u0645\u0639 \u0623\u0631\u0642\u0627\u0645\u0643 \u064a\u062f\u0648\u064a\u0627\u064b \u0642\u0628\u0644 \u0645\u0627 \u062a\u062f\u062e\u0644 \u0639\u0644\u064a\u0647.\n\n---\n\n\u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u0645\u0648 \u0641\u064a \u0627\u0644\u062a\u0646\u0638\u064a\u0645.\n\n\u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u0625\u0646\u0643 \u062a\u064f\u062f\u064a\u0631 \u0662\u0660+ \u0634\u0631\u0643\u0629 \u0628\u0623\u062f\u0648\u0627\u062a \u0645\u0627 \u0635\u064f\u0645\u0645\u062a \u0623\u0635\u0644\u0627\u064b \u0644\u0647\u0630\u0627 \u0627\u0644\u062d\u062c\u0645. \u0643\u0644 \u0639\u0645\u064a\u0644 \u062c\u062f\u064a\u062f \u064a\u0639\u0646\u064a \u0645\u062c\u0645\u0648\u0639\u0629 \u0648\u0627\u062a\u0633\u0627\u0628 \u062c\u062f\u064a\u062f\u0629\u060c \u0648\u0645\u0644\u0641 \u0625\u0643\u0633\u0644 \u062c\u062f\u064a\u062f\u060c \u0648\u0630\u0647\u0646 \u0645\u0631\u0647\u0642 \u0623\u0643\u062b\u0631. \u0627\u0644\u0633\u0642\u0641 \u0645\u0627 \u0648\u0635\u0644\u062a\u0647 \u0628\u0633\u0628\u0628 \u0646\u0642\u0635 \u0627\u0644\u0643\u0641\u0627\u0621\u0629 \u2014 \u0648\u0635\u0644\u062a\u0647 \u0644\u0623\u0646 \u0627\u0644\u0623\u062f\u0648\u0627\u062a \u0646\u0641\u0633\u0647\u0627 \u0648\u0635\u0644\u062a \u0644\u062d\u062f\u0647\u0627.\n\n---\n\n\u0633\u0624\u0627\u0644 \u0648\u0627\u062d\u062f \u0644\u0645\u0646 \u064a\u062f\u064a\u0631 \u0645\u0643\u062a\u0628 \u0633\u0646\u062f:\n\u0648\u064a\u0646 \u0643\u0627\u0646 \u0627\u0644\u062d\u062f \u0627\u0644\u0644\u064a \u0642\u0644\u062a \u0639\u0646\u062f\u0647 \"\u0645\u0627 \u0623\u0642\u062f\u0631 \u0623\u0633\u062a\u0642\u0628\u0644 \u0639\u0645\u0644\u0627\u0621 \u0623\u0643\u062b\u0631\"\u061f\n\n\u062c\u0631\u0651\u0628 \u0645\u0633\u0627\u0639\u062f \u0633\u0646\u062f \u0627\u0644\u0630\u0643\u064a \u0645\u062c\u0627\u0646\u0627\u064b \u2014 \u0625\u062c\u0627\u0628\u0627\u062a \u0641\u0648\u0631\u064a\u0629 \u0639\u0646 \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0648\u0627\u0644\u062a\u0623\u0634\u064a\u0631\u0627\u062a \u0648\u0627\u0644\u0631\u0633\u0648\u0645 \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629: www.thesmartpro.io/sanad/assistant\n\n#\u0645\u0643\u0627\u062a\u0628_\u0633\u0646\u062f\n#\u062e\u062f\u0645\u0627\u062a_PRO\n#\u0648\u0632\u0627\u0631\u0629_\u0627\u0644\u0639\u0645\u0644_\u0639\u064f\u0645\u0627\u0646\n#\u0625\u062f\u0627\u0631\u0629_\u0627\u0644\u0639\u0645\u0644\u064a\u0627\u062a\n#SmartProHub",
