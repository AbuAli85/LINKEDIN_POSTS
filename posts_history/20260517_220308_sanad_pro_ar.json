{
  "pillar": "sanad_pro_ar",
  "topic": "\u0625\u062f\u0627\u0631\u0629 \u062a\u0635\u0627\u0631\u064a\u062d \u0639\u0645\u0644 \u0645\u0648\u0638\u0641\u064a \u0639\u0645\u064a\u0644 \u0627\u0644\u0623\u0631\u0628\u0639\u064a\u0646 \u2014 \u0643\u0645 \u062a\u0627\u0631\u064a\u062e \u0627\u0646\u062a\u0647\u0627\u0621 \u0645\u062d\u0641\u0648\u0638 \u0641\u064a \u0630\u0627\u0643\u0631\u062a\u0643 \u0627\u0644\u0622\u0646\u061f",
  "format": "\u0627\u0641\u062a\u062d \u0628\u0633\u0624\u0627\u0644 \u064a\u064f\u062c\u0628\u0631 \u0627\u0644\u0642\u0627\u0631\u0626 \u0639\u0644\u0649 \u062d\u0633\u0627\u0628 \u0625\u062c\u0627\u0628\u062a\u0647: \u0643\u0645 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u062a\u062a\u0627\u0628\u0639\u0647 \u0627\u0644\u0622\u0646\u060c \u0648\u0623\u064a\u0646 \u0628\u0627\u0644\u0636\u0628\u0637 \u064a\u0648\u062c\u062f \u0647\u0630\u0627 \u0627\u0644\u0633\u062c\u0644\u061f",
  "language": "ar",
  "segment": "A",
  "publish_day": "Tuesday",
  "post": "\u0643\u0645 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u062a\u062a\u0627\u0628\u0639\u0647 \u0627\u0644\u062d\u064a\u0646 \u0644\u0639\u0645\u0644\u0627\u0626\u0643 \u2014 \u0648\u0623\u064a\u0646 \u0628\u0627\u0644\u0636\u0628\u0637 \u064a\u0648\u062c\u062f \u0647\u0630\u0627 \u0627\u0644\u0633\u062c\u0644\u061f\n\n\u062e\u0630 \u062b\u0627\u0646\u064a\u0629 \u0648\u0641\u0643\u0651\u0631.\n\n\u0625\u0630\u0627 \u0627\u0644\u062c\u0648\u0627\u0628 \"\u0641\u064a \u0625\u0643\u0633\u0644\" \u0623\u0648 \"\u0641\u064a \u0645\u062c\u0645\u0648\u0639\u0629 \u0648\u0627\u062a\u0633\u0627\u0628\" \u0623\u0648 \"\u0648\u0627\u0644\u0644\u0647 \u0645\u0627 \u0623\u062f\u0631\u064a \u0628\u0627\u0644\u0636\u0628\u0637\" \u2014 \u0647\u0630\u0627 \u0627\u0644\u0645\u0646\u0634\u0648\u0631 \u0644\u0643.\n\n---\n\n\u0639\u0645\u064a\u0644 \u0648\u0627\u062d\u062f \u0639\u0646\u062f\u0647 \u0664\u0660 \u0645\u0648\u0638\u0641 \u0648\u0627\u0641\u062f.\n\u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u0644\u0643\u0644 \u0648\u0627\u062d\u062f. \u062a\u0627\u0631\u064a\u062e \u0627\u0646\u062a\u0647\u0627\u0621 \u0645\u062e\u062a\u0644\u0641 \u2014 \u0628\u0639\u0636\u0647\u0627 \u0633\u0646\u0629\u060c \u0628\u0639\u0636\u0647\u0627 \u0633\u0646\u062a\u064a\u0646.\n\u0627\u0636\u0631\u0628 \u0647\u0630\u0627 \u0641\u064a \u0662\u0660 \u0634\u0631\u0643\u0629 \u0639\u0645\u064a\u0644 \u2014 \u062a\u0644\u0627\u0642\u064a \u0646\u0641\u0633\u0643 \u0634\u0627\u064a\u0644 \u0668\u0660\u0660 \u062a\u0627\u0631\u064a\u062e \u0627\u0646\u062a\u0647\u0627\u0621 \u0641\u064a \u0627\u0644\u0647\u0648\u0627\u0621.\n\n\u0645\u0648 \u0641\u064a \u0630\u0627\u0643\u0631\u062a\u0643. \u0641\u064a \u0625\u0643\u0633\u0644 \u0645\u0627 \u064a\u0641\u062a\u062d\u0647 \u0623\u062d\u062f \u0625\u0644\u0627 \u0644\u0645\u0627 \u064a\u0635\u064a\u0631 \u0634\u064a\u0621.\n\n---\n\n\u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u0645\u0648 \u0641\u064a \u0627\u0644\u062a\u0646\u0638\u064a\u0645 \u0627\u0644\u0634\u062e\u0635\u064a.\n\u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u0623\u0646 \u062a\u0635\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0645\u0627 \u0639\u0646\u062f\u0647 \u062a\u0646\u0628\u064a\u0647 \u062a\u0644\u0642\u0627\u0626\u064a.\n\u0648\u0627\u0643\u062a\u0634\u0641\u062a \u0627\u0644\u0627\u0646\u062a\u0647\u0627\u0621 \u0644\u0645\u0627 \u0627\u0644\u0639\u0645\u064a\u0644 \u0627\u062a\u0635\u0644 \u064a\u0633\u0623\u0644 \u2014 \u0628\u0639\u062f \u0645\u0627 \u0635\u0627\u0631 \u0627\u0644\u0645\u0634\u0643\u0644\u0629. \u0648\u0647\u0630\u0627 \u064a\u0635\u064a\u0631 \u0648\u0627\u064a\u062f\u060c \u0639\u0627\u062f.\n\n---\n\n\u062b\u0645\u0627\u0646\u064a\u0629 \u062a\u0633\u062c\u064a\u0644\u0627\u062a \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0639\u0645\u0644. \u062e\u0645\u0633\u0629 \u0639\u0634\u0631 \u062a\u0623\u0634\u064a\u0631\u0629 \u0625\u0642\u0627\u0645\u0629. \u0643\u0644 \u0639\u0645\u064a\u0644 \u0641\u064a \u0645\u062c\u0645\u0648\u0639\u0629 \u0648\u0627\u062a\u0633\u0627\u0628 \u0645\u0646\u0641\u0635\u0644\u0629.\n\u0648\u0623\u0646\u062a \u0641\u064a \u0627\u0644\u0646\u0635 \u062a\u062d\u0627\u0648\u0644 \u062a\u062a\u0630\u0643\u0631 \u0645\u064a\u0646 \u064a\u062d\u062a\u0627\u062c \u062a\u062c\u062f\u064a\u062f \u0627\u0644\u0623\u0633\u0628\u0648\u0639 \u0627\u0644\u062c\u0627\u064a.\n\n---\n\n\u0627\u0644\u0627\u062d\u062a\u0631\u0627\u0641\u064a\u0629 \u0641\u064a \u0625\u062f\u0627\u0631\u0629 \u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0645\u0627 \u062a\u0639\u0646\u064a \u0625\u0646\u0643 \u062a\u0643\u0648\u0646 \u0623\u0642\u0648\u0649 \u0630\u0627\u0643\u0631\u0629 \u0641\u064a \u0627\u0644\u0645\u0643\u062a\u0628.\n\u062a\u0639\u0646\u064a \u0625\u0646 \u0627\u0644\u0646\u0638\u0627\u0645 \u064a\u0630\u0643\u0651\u0631\u0643 \u2014 \u0642\u0628\u0644 \u0645\u0627 \u064a\u0635\u064a\u0631 \u0634\u064a\u0621.\n\nSmartPro Hub \u0635\u064f\u0645\u0651\u0645\u062a \u0644\u0647\u0630\u0627 \u0628\u0627\u0644\u0636\u0628\u0637: \u062a\u0646\u0628\u064a\u0647\u0627\u062a \u062a\u0644\u0642\u0627\u0626\u064a\u0629 \u0628\u0627\u0646\u062a\u0647\u0627\u0621 \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0648\u0627\u0644\u062a\u0623\u0634\u064a\u0631\u0627\u062a\u060c \u062e\u0632\u064a\u0646\u0629 \u0648\u062b\u0627\u0626\u0642 \u0631\u0642\u0645\u064a\u0629 \u0644\u0643\u0644 \u0639\u0645\u064a\u0644\u060c \u0648\u0628\u0648\u0627\u0628\u0629 \u064a\u062a\u0627\u0628\u0639 \u0641\u064a\u0647\u0627 \u0627\u0644\u0639\u0645\u064a\u0644 \u0637\u0644\u0628\u0627\u062a\u0647 \u062f\u0648\u0646 \u0645\u0627 \u064a\u062a\u0635\u0644 \u0639\u0644\u064a\u0643.\n\n\u062c\u0631\u0651\u0628 \u0645\u0633\u0627\u0639\u062f \u0633\u0646\u062f \u0627\u0644\u0630\u0643\u064a \u0645\u062c\u0627\u0646\u0627\u064b \u2014 \u0625\u062c\u0627\u0628\u0627\u062a \u0641\u0648\u0631\u064a\u0629 \u0639\u0646 \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0648\u0627\u0644\u062a\u0623\u0634\u064a\u0631\u0627\u062a \u0648\u0627\u0644\u0631\u0633\u0648\u0645 \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629: www.thesmartpro.io/sanad/assistant\n\n---\n\n\u0643\u0645 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u0639\u0646\u062f\u0643 \u0627\u0644\u062d\u064a\u0646 \u0642\u0627\u0639\u062f \u0639\u0644\u0649 \u0625\u0643\u0633\u0644 \u0628\u062f\u0648\u0646 \u062a\u0646\u0628\u064a\u0647\u061f\n\n#OmanBusiness\n#HRManagement\n#PayrollOman\n#WPS\n#SmartPro\n#Omanization\n#GCCBusiness",
