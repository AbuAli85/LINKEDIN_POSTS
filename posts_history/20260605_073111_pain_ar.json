{
  "pillar": "pain_ar",
  "topic": "\u0643\u0644 \u0639\u0645\u0644\u064a\u0629 \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u0641\u064a \u0634\u0631\u0643\u062a\u0643 \u0645\u0648\u062c\u0648\u062f\u0629 \u0641\u064a \u0630\u0647\u0646 \u0634\u062e\u0635 \u0648\u0627\u062d\u062f \u2014 \u0645\u0627\u0630\u0627 \u064a\u062d\u062f\u062b \u062d\u064a\u0646 \u064a\u0643\u0648\u0646 \u063a\u064a\u0631 \u0645\u062a\u0627\u062d\u061f",
  "format": "\u0627\u0641\u062a\u062d \u0628\u0644\u062d\u0638\u0629 \u0641\u0634\u0644 \u0645\u062d\u062f\u062f\u0629 \u2014 \u062a\u0627\u0631\u064a\u062e \u062d\u0642\u064a\u0642\u064a\u060c \u062a\u0643\u0644\u0641\u0629 \u062d\u0642\u064a\u0642\u064a\u0629\u060c \u0639\u0627\u0642\u0628\u0629 \u062d\u0642\u064a\u0642\u064a\u0629 \u064a\u062a\u0639\u0631\u0641 \u0639\u0644\u064a\u0647\u0627 \u0627\u0644\u0642\u0627\u0631\u0626 \u0641\u0648\u0631\u0627\u064b",
  "language": "ar",
  "segment": "A",
  "publish_day": "Sunday",
  "post": "\u0645\u062f\u064a\u0631 \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u0623\u062e\u0630 \u0625\u062c\u0627\u0632\u0629 \u0645\u0631\u0636\u064a\u0629 \u0627\u0644\u0623\u0631\u0628\u0639\u0627\u0621.\n\u0627\u0644\u0631\u0648\u0627\u062a\u0628 \u064a\u0648\u0645 \u0627\u0644\u0623\u062d\u062f.\n\n\u0644\u0627 \u0623\u062d\u062f \u064a\u0639\u0631\u0641 \u0643\u0644\u0645\u0629 \u0645\u0631\u0648\u0631 \u062d\u0633\u0627\u0628 WPS.\n\u0644\u0627 \u0623\u062d\u062f \u064a\u0639\u0631\u0641 \u0623\u064a\u0646 \u0645\u0644\u0641\u0627\u062a \u0639\u0642\u0648\u062f \u0627\u0644\u0639\u0645\u0644.\n\u0644\u0627 \u0623\u062d\u062f \u064a\u0639\u0631\u0641 \u0623\u064a \u0627\u0644\u0645\u0648\u0638\u0641\u064a\u0646 \u062a\u0635\u0627\u0631\u064a\u062d \u0639\u0645\u0644\u0647\u0645 \u062a\u0646\u062a\u0647\u064a \u0647\u0630\u0627 \u0627\u0644\u0634\u0647\u0631.\n\n\u0648\u0627\u0644\u0644\u0647\u060c \u0627\u0644\u0623\u0633\u0648\u0623 \u0645\u0648 \u063a\u064a\u0627\u0628 \u0627\u0644\u0634\u062e\u0635 \u2014 \u0627\u0644\u0623\u0633\u0648\u0623 \u0623\u0646 \u0627\u0644\u0645\u0639\u0644\u0648\u0645\u0629 \u0643\u0644\u0647\u0627 \u0643\u0627\u0646\u062a \u0641\u064a \u0631\u0623\u0633\u0647 \u0647\u0648.\n\n\u0647\u0630\u0627 \u0627\u0644\u0648\u0636\u0639 \u0634\u0627\u0626\u0639 \u0648\u0627\u064a\u062f\u060c \u0628\u0633 \u0645\u0627 \u0623\u062d\u062f \u064a\u062d\u0628 \u064a\u0639\u062a\u0631\u0641.\n\u0641\u064a \u0634\u0631\u0643\u0627\u062a \u0628\u064a\u0646 \u0661\u0665 \u0648\u0661\u0660\u0660 \u0645\u0648\u0638\u0641\u060c \u063a\u0627\u0644\u0628\u0627\u064b \u0634\u062e\u0635 \u0648\u0627\u062d\u062f \u0647\u0648 \u0627\u0644\u0644\u064a \u0634\u0627\u064a\u0644 \u0643\u0644 \u0634\u064a\u0621: \u0643\u0634\u0641 \u0627\u0644\u0631\u0648\u0627\u062a\u0628\u060c \u0631\u0635\u064a\u062f \u0627\u0644\u0625\u062c\u0627\u0632\u0627\u062a\u060c \u062a\u0648\u0627\u0631\u064a\u062e \u0627\u0646\u062a\u0647\u0627\u0621 \u062a\u0623\u0634\u064a\u0631\u0627\u062a \u0627\u0644\u0625\u0642\u0627\u0645\u0629\u060c \u0627\u0644\u0627\u0645\u062a\u062b\u0627\u0644 \u0644\u0635\u0646\u062f\u0648\u0642 \u0627\u0644\u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u0629\u060c \u0645\u062a\u0637\u0644\u0628\u0627\u062a \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0639\u0645\u0644.\n\u0645\u0627 \u0641\u064a \u0646\u0638\u0627\u0645. \u0641\u064a \u0648\u0627\u062a\u0633\u0627\u0628 \u0648\u0625\u0643\u0633\u0644 \u0648\u0630\u0627\u0643\u0631\u0629.\n\n\u062d\u064a\u0646 \u064a\u063a\u064a\u0628 \u0647\u0630\u0627 \u0627\u0644\u0634\u062e\u0635 \u2014 \u0645\u0631\u0636\u060c \u0627\u0633\u062a\u0642\u0627\u0644\u0629\u060c \u0623\u064a \u0634\u064a\u0621 \u2014 \u0627\u0644\u0634\u0631\u0643\u0629 \u062a\u062a\u0648\u0642\u0641.\n\u0645\u0648 \u062c\u0632\u0626\u064a\u0627\u064b. \u0643\u0644\u064a\u0627\u064b.\n\n\u0645\u062e\u0635\u0635 \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u062e\u062f\u0645\u0629 \u0645\u062d\u0633\u0648\u0628 \u0648\u064a\u0646 \u0628\u0627\u0644\u0636\u0628\u0637\u061f\n\u0646\u0633\u0628\u0629 \u0627\u0644\u062a\u0639\u0645\u064a\u0646 \u0645\u062d\u062f\u0651\u062b\u0629\u061f\n\u062a\u062c\u062f\u064a\u062f \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u2014 \u0645\u0646 \u064a\u062a\u0627\u0628\u0639\u0647\u0627 \u0627\u0644\u062d\u064a\u0646\u061f\n\nSmartPRO Hub \u0628\u064f\u0646\u064a \u0644\u0647\u0630\u0627 \u0628\u0627\u0644\u0636\u0628\u0637.\n\u0643\u0644 \u0645\u0639\u0644\u0648\u0645\u0629 \u0645\u0648\u0638\u0641\u060c \u0643\u0644 \u062a\u0627\u0631\u064a\u062e \u0627\u0645\u062a\u062b\u0627\u0644\u060c \u0643\u0644 \u0643\u0634\u0641 \u0631\u0648\u0627\u062a\u0628 WPS \u2014 \u0641\u064a \u0645\u0643\u0627\u0646 \u0648\u0627\u062d\u062f\u060c \u064a\u0635\u0644\u0647 \u0623\u064a \u0634\u062e\u0635 \u0645\u062e\u0648\u0651\u0644\u060c \u0641\u064a \u0623\u064a \u0648\u0642\