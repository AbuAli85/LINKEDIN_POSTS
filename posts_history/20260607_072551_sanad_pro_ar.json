{
  "pillar": "sanad_pro_ar",
  "topic": "\u0645\u0627 \u0627\u0644\u0630\u064a \u062a\u063a\u064a\u0651\u0631\u0647 \u062a\u0646\u0628\u064a\u0647\u0627\u062a \u0627\u0646\u062a\u0647\u0627\u0621 \u0635\u0644\u0627\u062d\u064a\u0629 \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0648\u0627\u0644\u062a\u0623\u0634\u064a\u0631\u0627\u062a \u0627\u0644\u062a\u0644\u0642\u0627\u0626\u064a\u0629 \u0641\u064a \u0627\u0644\u0631\u0648\u062a\u064a\u0646 \u0627\u0644\u064a\u0648\u0645\u064a \u0644\u0641\u0631\u064a\u0642 \u0645\u0643\u062a\u0628 \u0633\u0646\u062f",
  "format": "\u0627\u0641\u062a\u062d \u0628\u0631\u0642\u0645 \u064a\u0636\u0639 \u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u0641\u064a \u062d\u062c\u0645\u0647\u0627 \u0627\u0644\u062d\u0642\u064a\u0642\u064a \u2014 \u0669\u0662\u0664 \u0645\u0643\u062a\u0628\u0627\u064b\u060c \u0664\u0660 \u062a\u0635\u0631\u064a\u062d\u0627\u064b\u060c \u0661\u0665 \u062a\u0623\u0634\u064a\u0631\u0629\u060c \u0662\u0660\u0660 \u0645\u0639\u0627\u0645\u0644\u0629 \u0634\u0647\u0631\u064a\u0627\u064b \u2014 \u062b\u0645 \u0623\u0638\u0647\u0631 \u0643\u064a\u0641 \u064a\u0628\u062f\u0648 \u062a\u062a\u0628\u0639 \u0647\u0630\u0627 \u0627\u0644\u062d\u062c\u0645 \u064a\u062f\u0648\u064a\u0627\u064b",
  "language": "ar",
  "segment": "A",
  "publish_day": "Tuesday",
  "post": "\u0627\u0644\u0633\u0627\u0639\u0629 \u0668:\u0664\u0665 \u0635\u0628\u0627\u062d\u0627\u064b. \u0641\u062a\u062d\u062a \u0627\u0644\u0625\u0643\u0633\u0644 \u2014 \u0622\u062e\u0631 \u062a\u062d\u062f\u064a\u062b \u0627\u0644\u0623\u0633\u0628\u0648\u0639 \u0627\u0644\u0645\u0627\u0636\u064a.\n\n\u0664\u0660 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644. \u0661\u0665 \u062a\u0623\u0634\u064a\u0631\u0629 \u0625\u0642\u0627\u0645\u0629. \u0668 \u062a\u0633\u062c\u064a\u0644\u0627\u062a \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0639\u0645\u0644. \u0662\u0660 \u0634\u0631\u0643\u0629 \u0639\u0645\u064a\u0644.\n\u0643\u0644\u0647\u0627 \u0641\u064a \u0645\u0644\u0641 \u0648\u0627\u062d\u062f \u2014 \u0625\u0630\u0627 \u062a\u0630\u0643\u0651\u0631\u062a \u062a\u062d\u062f\u0651\u062b\u0647.\n\n\u0647\u0630\u0627 \u0647\u0648 \u0627\u0644\u0631\u0648\u062a\u064a\u0646 \u0627\u0644\u064a\u0648\u0645\u064a \u0644\u0648\u0627\u064a\u062f \u0645\u0646 \u0645\u0643\u0627\u062a\u0628 \u0633\u0646\u062f \u0627\u0644\u0640\u0669\u0662\u0664 \u0627\u0644\u0645\u0631\u062e\u0635\u0629 \u0641\u064a \u0639\u064f\u0645\u0627\u0646.\n\u0645\u0648 \u0646\u0642\u062f \u2014 \u0647\u0630\u0627 \u0648\u0635\u0641 \u0648\u0627\u0642\u0639 \u0627\u0634\u062a\u063a\u0644 \u0641\u064a\u0647 \u0646\u0627\u0633 \u064a\u0639\u0631\u0641\u0648\u0646 \u0634\u063a\u0644\u0647\u0645 \u0632\u064a\u0646.\n\n\u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u0645\u0648 \u0641\u064a \u0627\u0644\u0643\u0641\u0627\u0621\u0629. \u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u0641\u064a \u0627\u0644\u062d\u062c\u0645.\n\n\u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u064a\u0646\u062a\u0647\u064a \u0628\u0639\u062f \u0639\u0634\u0631\u0629 \u0623\u064a\u0627\u0645 \u2014 \u0648\u0623\u0646\u062a \u063a\u0627\u0631\u0642 \u0641\u064a \u0645\u0644\u0641 \u062b\u0627\u0646\u064a.\n\u0628\u0637\u0627\u0642\u0629 \u0625\u0642\u0627\u0645\u0629 \u0645\u0648\u0638\u0641 \u0627\u0646\u062a\u0647\u062a \u2014 \u0648\u0627\u0644\u0639\u0645\u064a\u0644 \u0627\u0643\u062a\u0634\u0641\u0647\u0627 \u0645\u0646 \u062c\u0647\u0629 \u062b\u0627\u0646\u064a\u0629\u060c \u0645\u0648 \u0645\u0646\u0643.\n\u062e\u0644\u0627\u0635\u060c \u0627\u0644\u0636\u0631\u0631 \u0635\u0627\u0631. \u0648\u0627\u0644\u062a\u0641\u0633\u064a\u0631 \u0645\u0627 \u064a\u062c\u064a \u0633\u0647\u0644.\n\n\u0627\u0644\u062a\u0646\u0628\u064a\u0647 \u0627\u0644\u062a\u0644\u0642\u0627\u0626\u064a \u064a\u063a\u064a\u0651\u0631 \u0645\u0639\u0627\u062f\u0644\u0629 \u0648\u0627\u062d\u062f\u0629 \u0628\u0633:\n\u0628\u062f\u0644 \u0645\u0627 \u062a\u062a\u0630\u0643\u0631 \u0623\u0646\u062a \u2014 \u0627\u0644\u0646\u0638\u0627\u0645 \u064a\u062a\u0630\u0643\u0631 \u0628\u062f\u0644\u0627\u064b \u0639\u0646\u0643.\n\n\u0642\u0628\u0644 \u0663\u0660 \u064a\u0648\u0645\u0627\u064b \u0645\u0646 \u0623\u064a \u0627\u0646\u062a\u0647\u0627\u0621 \u0635\u0644\u0627\u062d\u064a\u0629\u060c \u064a\u0635\u0644\u0643 \u062a\u0646\u0628\u064a\u0647 \u2014 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u0623\u0648 \u062a\u0623\u0634\u064a\u0631\u0629 \u0625\u0642\u0627\u0645\u0629.\n\u0642\u0628\u0644 \u0645\u0627 \u064a\u062a\u062d\u0648\u0644 \u0627\u0644\u0645\u0648\u0636\u0648\u0639 \u0644\u0645\u0634\u0643\u0644\u0629\u060c \u062a\u0643\u0648\u0646 \u0627\u0644\u062d\u064a\u0646 \u0648\u0627\u0642\u0641 \u0623\u0645\u0627\u0645\u0647\u0627.\n\nSmartPRO Hub \u0628\u0646\u064a\u0646\u0627\u0647\u0627 \u0639\u0644\u0649 \u0647\u0630\u0647 \u0627\u0644\u0641\u0643\u0631\u0629 \u062a\u062d\u062f\u064a\u062f\u0627\u064b:\n\u062a\u062a\u0628\u0639 \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0648\u0627\u0644\u062a\u0623\u0634\u064a\u0631\u0627\u062a \u0644\u0643\u0644 \u0639\u0645\u064a\u0644\u060c \u062a\u0646\u0628\u064a\u0647\u0627\u062a \u062a\u0644\u0642\u0627\u0626\u064a\u0629\u060c \u0648\u0648\u062b\u0627\u0626\u0642 \u0645\u0646\u0638\u0645\u0629 \u0641\u064a \u0645\u0643\u0627\u0646 \u0648\u0627\u062d\u062f \u2014 \u0628\u062f\u0644 \u0648\u0627\u062a\u0633\u0627\u0628 \u0648\u0625\u0643\u0633\u0644 \u0648\u0623\u0648\u0631\u0627\u0642 \u0645\u062a\u0641\u0631\u0642\u0629.\n\n\u0627\u0644\u0644\u064a \u064a\u0634\u063a\u0651\u0644 \u0662\u0660 \u0634\u0631\u0643\u0629 \u0639\u0645\u064a\u0644 \u064a\u0639\u0631\u0641: \u0627\u0644\u062e\u0637\u0623 \u0627\u0644\u0648\u062d\u064a\u062f \u0627\u0644\u0644\u064a \u0645\u0627 \u062a\u0642\u062f\u0631 \u062a\u0628\u0631\u0631\u0647 \u0647\u0648 \u0627\u0644\u062e\u0637\u0623 \u0627\u0644\u0644\u064a \u0643\u0627\u0646 \u0645\u0645\u0643\u0646 \u062a\u062a\u062c\u0646\u0628\u0647.\n\n\u0623\u0646\u062a \u0627\u0644\u062d\u064a\u0646 \u2014 \u0643\u064a\u0641 \u062a\u062a\u0627\u0628\u0639 \u0645\u0648\u0627\u0639\u064a\u062f \u0627\u0646\u062a\u0647\u0627\u0621 \u0635\u0644\u0627\u062d\u064a\u0629 \u062a\u0635\u0627\u0631\u064a\u062d \u0639\u0645\u0644 \u0639\u0645\u0644\u0627\u0626\u0643\u061f\n\n\u0627\u062d\u062c\u0632 \u0639\u0631\u0636\u0627\u064b \u062a\u062c\u0631\u064a\u0628\u064a\u0627\u064b \u0645\u062c\u0627\u0646\u064a\u0627\u064b \u0645\u062f\u062a\u0647 \u0662\u0660 \u062f\u0642\u064a\u0642\u0629: https://www.thesmartpro.io/demo?utm_source=linkedin&utm_medium=social&utm_campaign=sanad-pro-ar\n\u0623\u0648 \u0648\u0627\u062a\u0633\u0627\u0628: +96879665522\n\n#OmanBusiness\n#HRManagement\n#SmartPROHub\n#Omanization\n#GCCBusiness",
