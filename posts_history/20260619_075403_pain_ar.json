{
  "pillar": "pain_ar",
  "topic": "\u0643\u0644 \u0639\u0645\u0644\u064a\u0629 \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u0641\u064a \u0634\u0631\u0643\u062a\u0643 \u0645\u0648\u062c\u0648\u062f\u0629 \u0641\u064a \u0630\u0647\u0646 \u0634\u062e\u0635 \u0648\u0627\u062d\u062f \u2014 \u0645\u0627\u0630\u0627 \u064a\u062d\u062f\u062b \u062d\u064a\u0646 \u064a\u0643\u0648\u0646 \u063a\u064a\u0631 \u0645\u062a\u0627\u062d\u061f",
  "format": "\u0642\u0628\u0644 \u0648\u0628\u0639\u062f: \u0635\u0650\u0641\u0652 \u0628\u0627\u0644\u0636\u0628\u0637 \u0643\u064a\u0641 \u062a\u0628\u062f\u0648 \u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u062f\u0648\u0646 \u062d\u0644\u060c \u062b\u0645 \u0645\u0627 \u0627\u0644\u0630\u064a \u064a\u062a\u063a\u064a\u0631 \u062d\u064a\u0646 \u062a\u064f\u062d\u064e\u0644",
  "language": "ar",
  "segment": "A",
  "publish_day": "Sunday",
  "post": "\u0645\u062f\u064a\u0631 \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u0623\u062e\u0630 \u0625\u062c\u0627\u0632\u0629 \u0645\u0631\u0636\u064a\u0629. \u0648\u0627\u0644\u0634\u0631\u0643\u0629 \u0645\u0627 \u062a\u0639\u0631\u0641 \u0648\u064a\u0646 \u0639\u0642\u0648\u062f \u0627\u0644\u0645\u0648\u0638\u0641\u064a\u0646.\n\n\u0627\u0644\u0644\u064a \u0645\u0631\u0651 \u0628\u0647\u0630\u0627 \u0627\u0644\u0645\u0634\u0647\u062f \u064a\u0639\u0631\u0641 \u0627\u0644\u0625\u062d\u0633\u0627\u0633 \u0628\u0627\u0644\u0636\u0628\u0637.\n\n\u0631\u0635\u064a\u062f \u0625\u062c\u0627\u0632\u0629 \u0645\u0648\u0638\u0641\u061f \"\u0627\u0633\u0623\u0644 \u0641\u0644\u0627\u0646.\"\n\u0645\u0648\u0639\u062f \u0627\u0646\u062a\u0647\u0627\u0621 \u062a\u0635\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644\u061f \"\u0641\u0644\u0627\u0646 \u064a\u0634\u064a\u0644\u0647 \u0641\u064a \u0631\u0623\u0633\u0647.\"\n\u0646\u0633\u0628\u0629 \u0627\u0644\u062a\u0639\u0645\u064a\u0646 \u0647\u0630\u0627 \u0627\u0644\u0634\u0647\u0631\u061f \"\u0644\u0627\u0632\u0645 \u0646\u0646\u062a\u0638\u0631 \u064a\u0631\u062c\u0639.\"\n\n\u0648\u0627\u0644\u0623\u0633\u0648\u0623 \u2014 \u062d\u064a\u0646 \u064a\u0631\u062c\u0639 \"\u0641\u0644\u0627\u0646\"\u060c \u064a\u0643\u062a\u0634\u0641 \u0627\u0644\u062c\u0645\u064a\u0639 \u0623\u0646 \u0627\u0644\u0623\u0646\u0638\u0645\u0629 \u0627\u0644\u0645\u062a\u0641\u0631\u0642\u0629 \u0648\u0627\u0644\u062c\u062f\u0627\u0648\u0644 \u0641\u064a \u0627\u0644\u0625\u0643\u0633\u0644 \u0648\u0631\u0633\u0627\u0626\u0644 \u0627\u0644\u0648\u0627\u062a\u0633\u0627\u0628 \u0645\u0627 \u062a\u0639\u0648\u0651\u0636 \u0630\u0627\u0643\u0631\u062a\u0647. \u062e\u0644\u0627\u0635.\n\n\u0647\u0630\u0627 \u0645\u0648 \u0636\u0639\u0641 \u0641\u064a \u0627\u0644\u0641\u0631\u064a\u0642. \u0647\u0630\u0627 \u063a\u064a\u0627\u0628 \u062a\u0627\u0645 \u0644\u0644\u0639\u0645\u0644\u064a\u0627\u062a \u0627\u0644\u0645\u0648\u062b\u0651\u0642\u0629.\n\n\u0641\u064a \u0634\u0631\u0643\u0629 \u0628\u064a\u0646 \u0662\u0660 \u0648\u0661\u0660\u0660 \u0645\u0648\u0638\u0641\u060c \u0645\u062e\u0635\u0635 \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u062e\u062f\u0645\u0629 \u0648\u0645\u062a\u0627\u0628\u0639\u0629 \u0627\u0644\u0627\u0645\u062a\u062b\u0627\u0644 \u0644\u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0639\u0645\u0644 \u0648\u062a\u0642\u0627\u0631\u064a\u0631 WPS \u2014 \u0645\u0627 \u064a\u062c\u0628 \u0623\u0646 \u064a\u0633\u0643\u0646 \u0643\u0644 \u0647\u0630\u0627 \u0641\u064a \u0630\u0647\u0646 \u0634\u062e\u0635 \u0648\u0627\u062d\u062f.\n\n\u062d\u064a\u0646 \u062a\u0646\u062a\u0642\u0644 \u0647\u0630\u0647 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0625\u0644\u0649 \u0646\u0638\u0627\u0645 \u0648\u0627\u062d\u062f\u060c \u064a\u062a\u0648\u0642\u0641 \u0647\u0630\u0627 \u0627\u0644\u062e\u0648\u0641. \u0623\u064a \u0634\u062e\u0635 \u0641\u064a \u0627\u0644\u0641\u0631\u064a\u0642 \u064a\u0641\u062a\u062d \u0627\u0644\u0646\u0638\u0627\u0645 \u0648\u064a\u062c\u062f \u0643\u0644 \u0634\u064a\u0621: \u0639\u0642\u0648\u062f \u0627\u0644\u0639\u0645\u0644\u060c \u0631\u0635\u064a\u062f \u0627\u0644\u0625\u062c\u0627\u0632\u0629 \u0627\u0644\u0633\u0646\u0648\u064a\u0629\u060c \u062a\u0648\u0627\u0631\u064a\u062e \u062a\u062c\u062f\u064a\u062f \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644\u060c \u0648\u0627\u0633\u062a\u062d\u0642\u0627\u0642\u0627\u062a \u0635\u0646\u062f\u0648\u0642 \u0627\u0644\u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u0629 \u2014 \u0641\u064a \u0645\u0643\u0627\u0646 \u0648\u0627\u062d\u062f\u060c \u0645\u062a\u0627\u062d \u0627\u0644\u062d\u064a\u0646.\n\n\u0647\u0630\u0627 \u0645\u0627 \u064a\u0635\u0646\u0639\u0647 SmartPRO Hub \u0644\u0641\u0631\u0642 \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u0641\u064a \u0639\