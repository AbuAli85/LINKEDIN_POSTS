{
  "pillar": "sanad_pro_ar",
  "topic": "\u0669\u0662\u0664 \u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0641\u064a \u0639\u064f\u0645\u0627\u0646. \u064a\u0639\u0645\u0644 \u0628\u0647\u0627 \u0645\u0648\u0627\u0637\u0646\u0648\u0646 \u0639\u064f\u0645\u0627\u0646\u064a\u0648\u0646 \u062d\u0635\u0631\u0627\u064b. \u0645\u0639\u0638\u0645\u0647\u0627 \u064a\u064f\u062f\u064a\u0631 \u0663\u0660+ \u0639\u0645\u064a\u0644 \u0645\u0646 \u0645\u062c\u0645\u0648\u0639\u0629 \u0648\u0627\u062a\u0633\u0627\u0628 \u0648\u0627\u062d\u062f\u0629.",
  "format": "\u0627\u0641\u062a\u062d \u0628\u0644\u062d\u0638\u0629 \u0641\u0634\u0644 \u0645\u062d\u062f\u062f\u0629 \u0641\u064a \u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0623\u0648 PRO \u2014 \u062a\u0623\u0634\u064a\u0631\u0629 \u0627\u0646\u062a\u0647\u062a \u0635\u0644\u0627\u062d\u064a\u062a\u0647\u0627\u060c \u0639\u0645\u064a\u0644 \u0639\u0644\u0645 \u0641\u064a \u0627\u0644\u0645\u0637\u0627\u0631\u060c \u062a\u0633\u062c\u064a\u0644 \u0641\u0627\u062a \u0645\u0648\u0639\u062f\u0647 \u2014 \u0627\u062c\u0639\u0644\u0647\u0627 \u0645\u062d\u062f\u062f\u0629 \u0644\u062f\u0631\u062c\u0629 \u062a\u0648\u0642\u0641 \u0627\u0644\u0642\u0627\u0631\u0626 \u0639\u0646 \u0627\u0644\u062a\u0645\u0631\u064a\u0631",
  "language": "ar",
  "segment": "A",
  "publish_day": "Tuesday",
  "post": "\u0627\u0644\u0633\u0627\u0639\u0629 \u0661\u0661:\u0664\u0667 \u0645\u0633\u0627\u0621\u064b. \u0639\u0645\u064a\u0644 \u064a\u062a\u0635\u0644 \u0648\u0647\u0648 \u0648\u0627\u0642\u0641 \u0641\u064a \u0645\u0637\u0627\u0631 \u0645\u0633\u0642\u0637.\n\n\u062a\u0623\u0634\u064a\u0631\u0629 \u0625\u0642\u0627\u0645\u0629 \u0645\u0648\u0638\u0641\u0647 \u0627\u0646\u062a\u0647\u062a \u0642\u0628\u0644 \u0633\u062a\u0629 \u0623\u064a\u0627\u0645.\n\u0645\u0648 \u0623\u0645\u0633. \u0633\u062a\u0629 \u0623\u064a\u0627\u0645.\n\n\u0645\u0627 \u0623\u062d\u062f \u062a\u0646\u0628\u0651\u0647 \u2014 \u0644\u0627 \u0625\u0634\u0639\u0627\u0631\u060c \u0644\u0627 \u062a\u0630\u0643\u064a\u0631\u060c \u0644\u0627 \u0634\u064a\u0621.\n\u0627\u0644\u0645\u0644\u0641 \u0645\u0648\u062c\u0648\u062f \u0641\u064a \u062c\u0631\u0648\u0628 \u0627\u0644\u0648\u0627\u062a\u0633\u0627\u0628\u060c \u0645\u062f\u0641\u0648\u0646 \u062a\u062d\u062a \u0662\u0660\u0660 \u0631\u0633\u0627\u0644\u0629.\n\n\u0647\u0630\u0627 \u0645\u0648 \u0625\u0647\u0645\u0627\u0644. \u0647\u0630\u0627 \u0627\u0644\u0644\u064a \u064a\u0635\u064a\u0631 \u0644\u0645\u0627 \u062a\u062a\u0627\u0628\u0639 \u0663\u0660 \u0634\u0631\u0643\u0629 \u0639\u0645\u064a\u0644 \u2014 \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644\u060c \u0627\u0644\u062a\u0623\u0634\u064a\u0631\u0627\u062a\u060c \u0627\u0644\u062a\u0633\u062c\u064a\u0644\u0627\u062a \u2014 \u0645\u0646 \u0634\u0627\u0634\u0629 \u0648\u0627\u062d\u062f\u0629 \u0628\u062f\u0648\u0646 \u0646\u0638\u0627\u0645 \u062a\u0646\u0628\u064a\u0647.\n\n\u0669\u0662\u0664 \u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0645\u0631\u062e\u0635 \u0641\u064a \u0639\u064f\u0645\u0627\u0646.\n\u064a\u0639\u0645\u0644 \u0628\u0647\u0627 \u0645\u0648\u0627\u0637\u0646\u0648\u0646 \u0639\u064f\u0645\u0627\u0646\u064a\u0648\u0646 \u062d\u0635\u0631\u0627\u064b.\n\u0648\u0645\u0639\u0638\u0645\u0647\u0627 \u0634\u063a\u0651\u0627\u0644 \u0628\u0646\u0641\u0633 \u0627\u0644\u0637\u0631\u064a\u0642\u0629 \u2014 \u0648\u0627\u062a\u0633\u0627\u0628 \u0648\u0625\u0643\u0633\u0644 \u0648\u0633\u062c\u0644 \u0648\u0631\u0642\u064a.\n\n\u0645\u0648 \u0644\u0623\u0646 \u0623\u0635\u062d\u0627\u0628\u0647\u0627 \u063a\u064a\u0631 \u0645\u062d\u062a\u0631\u0641\u064a\u0646.\n\u0628\u0644 \u0644\u0623\u0646\u0647 \u0645\u0627 \u0643\u0627\u0646 \u0641\u064a \u0628\u062f\u064a\u0644 \u0645\u0635\u0645\u0645 \u0644\u0647\u0645 \u0628\u0627\u0644\u0630\u0627\u062a. \u062e\u0644\u0627\u0635.\n\nSmartPro Hub \u0635\u064f\u0645\u0645\u062a \u0644\u0645\u0643\u0627\u062a\u0628 \u0633\u0646\u062f \u062a\u062d\u062f\u064a\u062f\u0627\u064b:\n\u062a\u0646\u0628\u064a\u0647\u0627\u062a \u062a\u0644\u0642\u0627\u0626\u064a\u0629 \u0628\u0627\u0646\u062a\u0647\u0627\u0621 \u0643\u0644 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u0648\u062a\u0623\u0634\u064a\u0631\u0629 \u0625\u0642\u0627\u0645\u0629\u060c \u0645\u0644\u0641 \u0631\u0642\u0645\u064a \u0644\u0643\u0644 \u0634\u0631\u0643\u0629 \u0639\u0645\u064a\u0644\u060c \u0648\u0628\u0648\u0627\u0628\u0629 \u064a\u062a\u0627\u0628\u0639 \u0645\u0646\u0647\u0627 \u0627\u0644\u0639\u0645\u064a\u0644 \u0637\u0644\u0628\u0627\u062a\u0647 \u2014 \u0628\u062f\u0648\u0646 \u0645\u0627 \u064a\u062a\u0635\u0644 \u0639\u0644\u064a\u0643 \u0627\u0644\u0633\u0627\u0639\u0629 \u0661\u0661 \u0644\u064a\u0644.\n\n\u0648\u0641\u0648\u0642 \u0647\u0630\u0627 \u2014 \u0645\u0633\u0627\u0639\u062f \u0633\u0646\u062f \u0627\u0644\u0630\u0643\u064a \u0645\u062a\u0627\u062d \u0645\u062c\u0627\u0646\u0627\u064b\u060c \u0628\u062f\u0648\u0646 \u062a\u0633\u062c\u064a\u0644\u060c \u064a\u064f\u062c\u064a\u0628 \u0639\u0646 \u0631\u0633\u0648\u0645 \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0639\u0645\u0644 \u0648\u0627\u0644\u062a\u0623\u0634\u064a\u0631\u0627\u062a \u0648\u064a\u0648\u062c\u0651\u0647 \u0644\u0623\u0642\u0631\u0628 \u0645\u0643\u062a\u0628 \u0633\u0646\u062f:\nwww.thesmartpro.io/