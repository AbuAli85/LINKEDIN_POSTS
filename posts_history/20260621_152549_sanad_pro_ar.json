{
  "pillar": "sanad_pro_ar",
  "topic": "\u0645\u0646 \u0627\u0633\u062a\u0642\u0628\u0627\u0644 \u0627\u0644\u0637\u0644\u0628\u0627\u062a \u0628\u0648\u0627\u062a\u0633\u0627\u0628 \u0625\u0644\u0649 \u062a\u062a\u0628\u0639 \u0627\u0644\u0642\u0636\u0627\u064a\u0627 \u0627\u0644\u0645\u0646\u0638\u0651\u0645: \u0627\u0644\u0634\u0647\u0631 \u0627\u0644\u0623\u0648\u0644 \u0644\u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0628\u0639\u062f \u0627\u0644\u062a\u062d\u0648\u0644",
  "format": "\u0627\u0628\u0646\u0650 \u0645\u0642\u0627\u0631\u0646\u0629 \u062d\u0627\u062f\u0629 \u0642\u0628\u0644/\u0628\u0639\u062f: \u0625\u062f\u0627\u0631\u0629 \u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629 \u0628\u0648\u0627\u062a\u0633\u0627\u0628 \u0648\u0625\u0643\u0633\u0644 \u0645\u0642\u0627\u0628\u0644 SmartPRO Hub \u2014 \u0646\u0641\u0633 \u0627\u0644\u0623\u0633\u0628\u0648\u0639\u060c \u062a\u062c\u0631\u0628\u0629 \u0645\u062e\u062a\u0644\u0641\u0629 \u062a\u0645\u0627\u0645\u0627\u064b",
  "language": "ar",
  "segment": "A",
  "publish_day": "Tuesday",
  "post": "\u0627\u0644\u0623\u0633\u0628\u0648\u0639 \u0646\u0641\u0633\u0647. \u0634\u0631\u0643\u062a\u0627\u0646 \u0645\u0646 \u0639\u0645\u0644\u0627\u0626\u0643. \u062a\u062c\u0631\u0628\u0629 \u0645\u062e\u062a\u0644\u0641\u0629 \u062a\u0645\u0627\u0645\u0627\u064b.\n\n---\n\n\u0627\u0644\u0623\u0648\u0644: \u0623\u0631\u0633\u0644 \u0637\u0644\u0628 \u062a\u062c\u062f\u064a\u062f \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u0627\u0644\u0623\u062d\u062f \u0627\u0644\u0635\u0628\u062d.\n\u0628\u0639\u062f\u064a\u0646 \u0633\u0623\u0644\u0643 \u0627\u0644\u0623\u0631\u0628\u0639\u0627\u0621 \u2014 \u0645\u0627 \u0631\u062f.\n\u0628\u0639\u062f\u064a\u0646 \u0635\u0627\u062d\u0628 \u0627\u0644\u0634\u0631\u0643\u0629 \u0643\u0644\u0651\u0645 \u0645\u0648\u0638\u0641\u0643 \u0645\u0628\u0627\u0634\u0631\u0629.\n\u0628\u0639\u062f\u064a\u0646 \u0627\u0644\u0645\u0648\u0638\u0641 \u0645\u0627 \u0639\u0646\u062f\u0647 \u062c\u0648\u0627\u0628\u060c \u0644\u0623\u0646 \u0627\u0644\u0637\u0644\u0628 \u0636\u0627\u0639 \u0641\u064a \u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0629 \u0628\u064a\u0646 \u0664\u0660 \u0631\u0633\u0627\u0644\u0629.\n\n\u0627\u0644\u062b\u0627\u0646\u064a: \u0641\u062a\u062d \u0628\u0648\u0627\u0628\u0629 \u0627\u0644\u0639\u0645\u064a\u0644. \u0634\u0627\u0641 \u062d\u0627\u0644\u0629 \u0637\u0644\u0628\u0647 \u0628\u0646\u0641\u0633\u0647. \u0645\u0627 \u0627\u062d\u062a\u0627\u062c \u064a\u0643\u0644\u0645 \u0623\u062d\u062f.\n\n---\n\n\u0648\u0627\u0644\u0644\u0647\u060c \u0647\u0630\u0627 \u0645\u0648 \u0641\u0631\u0642 \u0641\u064a \u0627\u0644\u0623\u062f\u0648\u0627\u062a.\n\u0647\u0630\u0627 \u0641\u0631\u0642 \u0641\u064a \u0643\u064a\u0641 \u064a\u0634\u0648\u0641\u0643 \u0627\u0644\u0639\u0645\u064a\u0644.\n\n---\n\n\u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0627\u0644\u0644\u064a \u064a\u0634\u062a\u063a\u0644 \u0628\u0648\u0627\u062a\u0633\u0627\u0628 \u0648\u0625\u0643\u0633\u0644 \u064a\u0642\u0636\u064a \u0633\u0627\u0639\u0627\u062a \u0643\u0644 \u064a\u0648\u0645 \u064a\u0631\u062f \u0639\u0644\u0649 \"\u0648\u064a\u0646 \u0648\u0635\u0644 \u0627\u0644\u0637\u0644\u0628\u061f\"\n\u0645\u0648 \u0644\u0623\u0646\u0647 \u0645\u0627 \u064a\u0639\u0631\u0641 \u0634\u063a\u0644\u0647 \u2014 \u0628\u0633 \u0644\u0623\u0646 \u0627\u0644\u0646\u0638\u0627\u0645 \u0623\u0635\u0644\u0627\u064b \u0645\u0627 \u0628\u064f\u0646\u064a \u0644\u0639\u0634\u0631\u064a\u0646 \u0634\u0631\u0643\u0629 \u0639\u0645\u064a\u0644 \u0628\u0622\u0646 \u0648\u0627\u062d\u062f.\n\n\u0669\u0662\u0664 \u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0645\u0631\u062e\u0635 \u0641\u064a \u0639\u064f\u0645\u0627\u0646.\n\u0645\u0639\u0638\u0645\u0647\u0627 \u064a\u064f\u062f\u064a\u0631 \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0648\u0627\u0644\u062a\u0623\u0634\u064a\u0631\u0627\u062a \u0648\u0645\u0639\u0627\u0645\u0644\u0627\u062a \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0639\u0645\u0644 \u0645\u0646 \u0646\u0641\u0633 \u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0629.\n\u0627\u0644\u0646\u0638\u0627\u0645 \u062a\u0639\u0628\u0627\u0646 \u2014 \u0645\u0648 \u0627\u0644\u0646\u0627\u0633.\n\n---\n\nSmartPRO Hub \u0628\u064f\u0646\u064a \u0644\u0647\u0630\u0627 \u062a\u062d\u062f\u064a\u062f\u0627\u064b:\n\u0643\u0644 \u0639\u0645\u064a\u0644 \u0645\u0644\u0641 \u0645\u0633\u062a\u0642\u0644. \u0643\u0644 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u062a\u0646\u0628\u064a\u0647 \u062a\u0644\u0642\u0627\u0626\u064a \u0642\u0628\u0644 \u0627\u0646\u062a\u0647\u0627\u0626\u0647. \u0643\u0644 \u062e\u062f\u0645\u0629 \u0641\u0627\u062a\u0648\u0631\u0629 \u062c\u0627\u0647\u0632\u0629.\n\u0648\u0628\u0648\u0627\u0628\u0629 \u0639\u0645\u064a\u0644 \u0645\u0627 \u062a\u062d\u062a\u0627\u062c \u0641\u064a\u0647\u0627 \u062a\u0634\u0631\u062d \u0634\u064a\u0621 \u2014 \u0627\u0644\u0639\u0645\u064a\u0644 \u064a\u0634\u0648\u0641 \u0643\u0644 \u0634\u064a\u0621 \u0628\u0646\u0641\u0633\u0647\u060c \u062e\u0644\u0627\u0635.\n\n\u0627\u0644\u0634\u0647\u0631 \u0627\u0644\u0623\u0648\u0644 \u0628\u0639\u062f \u0627\u0644\u062a\u062d\u0648\u0644\u061f\n\u0631\u0633\u0627\u0626\u0644 \"\u0648\u064a\u0646 \u0648\u0635\u0644 \u0637\u0644\u0628\u064a\u061f\" \u062a\u0646\u062e\u0641\u0636. \u0648\u0648\u0642\u062a\u0643 \u064a\u0631\u062c\u0639 \u0644\u0643.\n\n---\n\n\u062c\u0631\u0651\u0628 \u0645\u0633\u0627\u0639\u062f \u0633\u0646\u062f \u0627\u0644\u0630\u0643\u064a \u0645\u062c\u0627\u0646\u0627\u064b \u2014 \u0625\u062c\u0627\u0628\u0627\u062a \u0641\u0648\u0631\u064a\u0629 \u0639\u0646 \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0648\u0627\u0644\u062a\u0623\u0634\u064a\u0631\u0627\u062a \u0648\u0627\u0644\u0631\u0633\u0648\u0645 \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629:\nwww.thesmartpro.io/sanad/assistant\n\n\u0627\u062d\u062c\u0632 \u0639\u0631\u0636\u0627\u064b \u062a\u062c\u0631\u064a\u0628\u064a\u0627\u064b \u0645\u062c\u0627\u0646\u064a\u0627\u064b \u0645\u062f\u062a\u0647 \u0663\u0660 \u062f\u0642\u064a\u0642\u0629:\nhttps://www.thesmartpro.io/demo?utm_source=linkedin&utm_medium=social&utm_campaign=sanad-pro-ar\n\n\u0623\u0648 \u0648\u0627\u062a\u0633\u0627\u0628: +96879665522\n\n---\n\n\u0633\u0624\u0627\u0644 \u0644\u0623\u0635\u062d\u0627\u0628 \u0645\u0643\u0627\u062a\u0628 \u0633\u0646\u062f: \u0643\u0645 \u0631\u0633\u0627\u0644\u0629 \"\u0648\u064a\u0646 \u0648\u0635\u0644 \u0637\u0644\u0628\u064a\u061f\" \u062a\u0633\u062a\u0642\u0628\u0644 \u064a\u0648\u0645\u064a\u0627\u064b\u061f\n\n#OmanBusiness\n#HRManagement\n#SmartPROHub\n#Omanization\n#GCCBusiness",
