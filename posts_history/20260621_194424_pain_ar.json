{
  "pillar": "pain_ar",
  "topic": "\u0627\u0644\u062a\u0643\u0644\u0641\u0629 \u0627\u0644\u062e\u0641\u064a\u0629 \u0644\u0625\u062f\u0627\u0631\u0629 \u0637\u0644\u0628\u0627\u062a \u0627\u0644\u0625\u062c\u0627\u0632\u0629 \u0639\u0628\u0631 \u0645\u062c\u0645\u0648\u0639\u0627\u062a \u0648\u0627\u062a\u0633\u0627\u0628",
  "format": "\u0627\u0643\u062a\u0628 \u0642\u0627\u0626\u0645\u0629 \u0645\u0631\u0642\u0651\u0645\u0629 \u0645\u0646 \u0664-\u0665 \u0639\u0644\u0627\u0645\u0627\u062a \u062a\u062d\u0630\u064a\u0631\u064a\u0629 \u2014 \u0643\u0646 \u0645\u062d\u062f\u062f\u0627\u064b \u0628\u0645\u0627 \u064a\u0643\u0641\u064a \u0644\u064a\u062a\u0639\u0631\u0641 \u0627\u0644\u0642\u0627\u0631\u0626 \u0639\u0644\u0649 \u062b\u0644\u0627\u062b \u0645\u0646\u0647\u0627 \u0639\u0644\u0649 \u0627\u0644\u0623\u0642\u0644",
  "language": "ar",
  "segment": "A",
  "publish_day": "Sunday",
  "post": "\u0637\u0644\u0628 \u0625\u062c\u0627\u0632\u0629 \u0648\u0635\u0644\u0643 \u0639\u0644\u0649 \u0648\u0627\u062a\u0633\u0627\u0628 \u0627\u0644\u0633\u0627\u0639\u0629 \u0661\u0661 \u0645\u0633\u0627\u0621\u064b.\n\u0645\u0627 \u0631\u062f\u0651\u064a\u062a \u2014 \u0646\u0633\u064a\u062a.\n\u0627\u0644\u0645\u0648\u0638\u0641 \u063a\u0627\u0628 \u0627\u0644\u0635\u0628\u062d. \u0648\u0627\u0644\u062d\u064a\u0646 \u0623\u0646\u062a \u0634\u0627\u064a\u0644 \u0627\u0644\u0645\u0634\u0643\u0644\u0629.\n\n\u0625\u0630\u0627 \u062a\u0639\u0631\u0651\u0641\u062a \u0639\u0644\u0649 \u0647\u0630\u0627 \u0627\u0644\u0645\u0634\u0647\u062f\u060c \u062a\u0623\u0645\u0644 \u0647\u0630\u0647 \u0627\u0644\u0639\u0644\u0627\u0645\u0627\u062a:\n\n\u0661. \u0637\u0644\u0628\u0627\u062a \u0627\u0644\u0625\u062c\u0627\u0632\u0629 \u062a\u0623\u062a\u064a\u0643 \u0639\u0628\u0631 \u0648\u0627\u062a\u0633\u0627\u0628 \u0623\u0648 \"\u0643\u0644\u0627\u0645 \u0639\u0644\u0649 \u0627\u0644\u062c\u0646\u0628\" \u2014 \u0648\u0645\u0627 \u0641\u064a \u0633\u062c\u0644 \u0631\u0633\u0645\u064a \u0644\u0623\u064a \u0645\u0646\u0647\u0627.\n\n\u0662. \u0645\u0648\u0638\u0641 \u064a\u0642\u0648\u0644 \"\u0623\u062e\u0630\u062a \u0625\u0630\u0646\u0627\u064b\" \u0648\u0623\u0646\u062a \u0645\u0627 \u062a\u0630\u0643\u0631 \u2014 \u0648\u0631\u0635\u064a\u062f \u0627\u0644\u0625\u062c\u0627\u0632\u0629 \u0627\u0644\u0633\u0646\u0648\u064a\u0629 \u0645\u0627 \u064a\u0637\u0627\u0628\u0642 \u0623\u064a \u0634\u064a\u0621 \u0639\u0646\u062f\u0643.\n\n\u0663. \u0639\u0646\u062f \u062a\u062d\u0636\u064a\u0631 \u0643\u0634\u0641 \u0627\u0644\u0631\u0648\u0627\u062a\u0628\u060c \u062a\u0631\u0627\u062c\u0639 \u0623\u064a\u0627\u0645 \u0627\u0644\u063a\u064a\u0627\u0628 \u064a\u062f\u0648\u064a\u0627\u064b \u2014 \u0648\u0627\u062d\u062f\u0627\u064b \u0648\u0627\u062d\u062f\u0627\u064b.\n\n\u0664. \u062a\u062d\u0633\u0628 \u0645\u062e\u0635\u0635 \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u062e\u062f\u0645\u0629 \u0641\u064a Excel\u060c \u0648\u0628\u0639\u062f\u064a\u0646 \u062a\u0633\u0623\u0644 \u0646\u0641\u0633\u0643: \u0647\u0644 \u0623\u062f\u062e\u0644\u062a \u0627\u0644\u0631\u0627\u062a\u0628 \u0627\u0644\u0623\u0633\u0627\u0633\u064a \u0627\u0644\u0635\u062d\u061f\n\n\u0665. \u064a\u0637\u0644\u0628\u0648\u0646 \u0645\u0646\u0643 \u062a\u0642\u0631\u064a\u0631 \u0631\u0635\u064a\u062f \u0625\u062c\u0627\u0632\u0627\u062a \u0627\u0644\u0641\u0631\u064a\u0642 \u2014 \u0648\u062a\u062d\u062a\u0627\u062c \u064a\u0648\u0645\u064a\u0646 \u0644\u062a\u062c\u0645\u0639 \u0627\u0644\u0623\u0631\u0642\u0627\u0645 \u0645\u0646 \u0623\u0645\u0627\u0643\u0646 \u0645\u062e\u062a\u0644\u0641\u0629.\n\n\u0647\u0630\u0627 \u0645\u0648 \u062a\u0642\u0635\u064a\u0631 \u0645\u0646\u0643.\n\u0647\u0630\u0627 \u0645\u0627 \u064a\u062d\u062f\u062b \u062d\u064a\u0646 \u062a\u064f\u062f\u0627\u0631 \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u0628\u0623\u062f\u0648\u0627\u062a \u0645\u0627 \u0635\u064f\u0645\u0651\u0645\u062a \u0644\u0647\u0627.\n\n\u0627\u0644\u062a\u0643\u0644\u0641\u0629 \u0627\u0644\u062d\u0642\u064a\u0642\u064a\u0629 \u0645\u0648 \u0641\u064a \u0627\u0644\u0623\u062e\u0637\u0627\u0621 \u0628\u0633 \u2014 \u0641\u064a \u0627\u0644\u0648\u0642\u062a \u0627\u0644\u0636\u0627\u0626\u0639 \u0643\u0644 \u0623\u0633\u0628\u0648\u0639\u060c \u0648\u0641\u064a \u0627\u0644\u0642\u0631\u0627\u0631\u0627\u062a \u0627\u0644\u0644\u064a \u062a\u064f\u0628\u0646\u0649 \u0639\u0644\u0649 \u0645\u0639\u0644\u0648\u0645\u0629 \u0646\u0627\u0642\u0635\u0629.\n\nSmartPRO Hub \u064a\u062c\u0645\u0639 \u0625\u062f\u0627\u0631\u0629 \u0627\u0644\u0625\u062c\u0627\u0632\u0627\u062a \u0648\u0633\u062c\u0644 \u0627\u0644\u062d\u0636\u0648\u0631 \u0648\u0643\u0634\u0641 \u0627\u0644\u0631\u0648\u0627\u062a\u0628 \u0645\u0639 \u0646\u0638\u0627\u0645 \u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0623\u062c\u0648\u0631 \u0641\u064a \u0645\u0646\u0635\u0629 \u0648\u0627\u062d\u062f\u0629 \u2014 \u0645\u0635\u0645\u0645\u0629 \u0644\u0634\u0631\u0643\u0627\u062a \u0639\u064f\u0645\u0627\u0646 \u0645\u0646 \u0661\u0660 \u0645\u0648\u0638\u0641\u064a\u0646 \u0641\u0623\u0643\u062b\u0631.\n\n\u062e\u0644\u0627\u0635\u060c \u0645\u0627 \u064a\u0635\u064a\u0631 \u0646\u0643\u0645\u0644 \u0647\u0643\u0630\u0627.\n\n\u0627\u062d\u062c\u0632 \u0639\u0631\u0636\u0627\u064b \u062a\u062c\u0631\u064a\u0628\u064a\u0627\u064b \u0645\u062c\u0627\u0646\u064a\u0627\u064b \u0645\u062f\u062a\u0647 \u0663\u0660 \u062f\u0642\u064a\u0642\u0629:\nhttps://www.thesmartpro.io/demo?utm_source=linkedin&utm_medium=social&utm_campaign=pain-ar\n\u0623\u0648 \u0648\u0627\u062a\u0633\u0627\u0628 +96879665522\n\n\u0643\u0645 \u0633\u0627\u0639\u0629 \u062a\u0642\u0636\u064a\u0647\u0627 \u0623\u0633\u0628\u0648\u0639\u064a\u0627\u064b \u0641\u064a \u062a\u062a\u0628\u0639 \u0627\u0644\u0625\u062c\u0627\u0632\u0627\u062a \u064a\u062f\u0648\u064a\u0627\u064b\u061f\n\n#OmanBusiness\n#HRManagement\n#PayrollOman\n#WPS\n#SmartPROHub\n#Omanization\n#GCCBusiness",
