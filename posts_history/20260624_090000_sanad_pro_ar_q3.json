{
  "pillar": "sanad_pro_ar",
  "segment": "arabic_audience",
  "hook": "story",
  "hook_text": "\u0642\u0636\u0649 \u0645\u0633\u0624\u0648\u0644 \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u0663 \u0633\u0646\u0648\u0627\u062a \u064a\u062a\u0635\u0644 \u0628\u0633\u0646\u0627\u062f \u0643\u0644 \u0623\u0633\u0628\u0648\u0639\u060c \u062f\u0648\u0646 \u0623\u0646 \u064a\u0639\u0631\u0641 \u0623\u0646 \u0647\u0646\u0627\u0643 \u0637\u0631\u064a\u0642\u0629 \u0623\u0641\u0636\u0644.",
  "body": "\u0623\u062d\u0645\u062f \u0645\u0633\u0624\u0648\u0644 \u0645\u0648\u0627\u0631\u062f \u0628\u0634\u0631\u064a\u0629 \u0641\u064a \u0634\u0631\u0643\u0629 \u0645\u0642\u0627\u0648\u0644\u0627\u062a \u0628\u0645\u0633\u0642\u0637.\n\n\u0643\u0644 \u0623\u0633\u0628\u0648\u0639: \u0645\u0643\u0627\u0644\u0645\u0629 \u0647\u0627\u062a\u0641\u064a\u0629 \u0644\u0633\u0646\u0627\u062f \u0644\u0644\u062a\u062d\u0642\u0642 \u0645\u0646 \u062d\u0627\u0644\u0629 \u0627\u0644\u0639\u0645\u0627\u0644.\n\n\u0643\u0644 \u0623\u0633\u0628\u0648\u0639: \u0627\u0646\u062a\u0638\u0627\u0631\u060c \u0648\u062a\u062d\u0648\u064a\u0644\u060c \u0648\u0623\u062d\u064a\u0627\u0646\u0627\u064b \u0639\u062f\u0645 \u0631\u062f.\n\n\u0643\u0644 \u0623\u0633\u0628\u0648\u0639: \u062a\u062f\u0648\u064a\u0646 \u0627\u0644\u0645\u0644\u0627\u062d\u0638\u0627\u062a \u064a\u062f\u0648\u064a\u0627\u064b \u0641\u064a \u0645\u0644\u0641 Excel.\n\n\u0663 \u0633\u0646\u0648\u0627\u062a \u00d7 \u0665\u0662 \u0623\u0633\u0628\u0648\u0639\u0627\u064b = \u0661\u0665\u0666 \u0645\u0643\u0627\u0644\u0645\u0629.\n\n\u0639\u0646\u062f\u0645\u0627 \u0634\u0631\u062d\u0646\u0627 \u0644\u0647 SmartPRO Hub\u060c \u0643\u0627\u0646 \u0631\u062f\u0647:\n\n\u00ab\u0623\u064a \u0623\u0646\u0646\u064a \u0623\u0633\u062a\u0637\u064a\u0639 \u0631\u0624\u064a\u0629 \u062d\u0627\u0644\u0629 \u0643\u0644 \u0639\u0627\u0645\u0644 \u0628\u0636\u063a\u0637\u0629 \u0648\u0627\u062d\u062f\u0629\u061f\u00bb\n\n\u0646\u0639\u0645.\n\n\u00ab\u0648\u0625\u0630\u0627 \u0627\u0646\u062a\u0647\u062a \u0635\u0644\u0627\u062d\u064a\u0629 \u062a\u0623\u0634\u064a\u0631\u0629 \u0623\u064a \u0639\u0627\u0645\u0644\u060c \u064a\u0635\u0644\u0646\u064a \u0625\u0634\u0639\u0627\u0631 \u062a\u0644\u0642\u0627\u0626\u064a\u061f\u00bb\n\n\u0646\u0639\u0645.\n\n\u00ab\u0648\u0623\u0633\u062a\u0637\u064a\u0639 \u0625\u0635\u062f\u0627\u0631 \u062a\u0642\u0631\u064a\u0631 \u0633\u0646\u0627\u062f \u0643\u0627\u0645\u0644 \u0644\u0644\u0645\u062f\u064a\u0631 \u0641\u064a \u062b\u0627\u0646\u064a\u0629\u061f\u00bb\n\n\u0646\u0639\u0645.\n\n\u0635\u0645\u062a \u0644\u062d\u0638\u0629.\n\n\u062b\u0645 \u0642\u0627\u0644: \u00ab\u0644\u0645\u0627\u0630\u0627 \u0644\u0645 \u064a\u0643\u0646 \u0647\u0630\u0627 \u0627\u0644\u062d\u0644 \u0645\u0648\u062c\u0648\u062f\u0627\u064b \u0645\u0646\u0630 \u0632\u0645\u0646\u061f\u00bb\n\n\u0627\u0644\u062c\u0648\u0627\u0628: \u0643\u0627\u0646 \u0645\u0648\u062c\u0648\u062f\u0627\u064b \u2014 \u0644\u0643\u0646 \u0644\u064a\u0633 \u0645\u0635\u0645\u0645\u0627\u064b \u0644\u0644\u0633\u0648\u0642 \u0627\u0644\u0639\u064f\u0645\u0627\u0646\u064a \u062a\u062d\u062f\u064a\u062f\u0627\u064b.\n\n\u062d\u062a\u0649 \u0627\u0644\u0622\u0646.",
  "cta": "\u0643\u0645 \u0645\u0643\u0627\u0644\u0645\u0629 \u0642\u0636\u064a\u062a\u064e \u0645\u0639 \u0633\u0646\u0627\u062f \u0647\u0630\u0627 \u0627\u0644\u0634\u0647\u0631\u061f\n\u062a\u0648\u0627\u0635\u0644 \u0645\u0639\u0646\u0627: smartprohub.com",
