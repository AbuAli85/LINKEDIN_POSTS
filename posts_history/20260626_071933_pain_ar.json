  "topic": "\u0643\u0645 \u0633\u0627\u0639\u0629 \u064a\u0642\u0636\u064a \u0641\u0631\u064a\u0642 HR \u0644\u062f\u064a\u0643 \u0641\u064a \u0625\u0639\u062f\u0627\u062f \u0627\u0644\u0631\u0648\u0627\u062a\u0628 \u0643\u0644 \u0634\u0647\u0631\u061f \u0648\u0645\u0627 \u0642\u064a\u0645\u0629 \u0647\u0630\u0627 \u0627\u0644\u0648\u0642\u062a \u062d\u0642\u0627\u064b\u061f",
  "format": "\u0627\u0630\u0643\u0631 \u0627\u0644\u062d\u0642\u064a\u0642\u0629 \u0627\u0644\u0645\u0632\u0639\u062c\u0629 \u0639\u0646 \u0637\u0631\u064a\u0642\u0629 \u0645\u0639\u0638\u0645 \u0627\u0644\u0634\u0631\u0643\u0627\u062a \u0641\u064a \u0639\u064f\u0645\u0627\u0646 \u0644\u0644\u062a\u0639\u0627\u0645\u0644 \u0645\u0639 \u0647\u0630\u0647 \u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u2014 \u0643\u0646 \u0645\u062d\u062f\u062f\u0627\u064b \u0648\u0635\u0627\u062f\u0642\u0627\u064b \u0644\u0627 \u0648\u0627\u0639\u0638\u0627\u064b",
  "language": "ar",
  "segment": "A",
  "publish_day": "Sunday",
  "post": "\u0627\u0644\u0633\u0627\u0639\u0629 \u0661\u0661:\u0660\u0660 \u0644\u064a\u0644\u0627\u064b. \u0645\u062f\u064a\u0631 \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u0644\u0627 \u064a\u0632\u0627\u0644 \u064a\u062d\u062f\u0651\u0642 \u0641\u064a \u0625\u0643\u0633\u0644.\n\n\u0633\u062a\u0629 \u0623\u0648\u0631\u0627\u0642. \u0645\u0639\u0627\u062f\u0644\u0627\u062a \u0645\u0643\u0633\u0648\u0631\u0629 \u0645\u0646 \u0662\u0660\u0662\u0662. \u0648\u062a\u0639\u062f\u064a\u0644 \u0622\u062e\u0631 \u0644\u062d\u0638\u0629 \u0648\u0635\u0644 \u0645\u0646 \u0627\u0644\u0645\u062f\u064a\u0631 \u0627\u0644\u0645\u0627\u0644\u064a \u0642\u0628\u0644 \u0631\u0628\u0639 \u0633\u0627\u0639\u0629.\n\n\u0647\u0630\u0627 \u0627\u0644\u0645\u0634\u0647\u062f \u064a\u062a\u0643\u0631\u0631 \u0641\u064a \u0634\u0631\u0643\u0627\u062a \u0648\u0627\u064a\u062f \u0628\u0639\u064f\u0645\u0627\u0646 \u2014 \u0643\u0644 \u0634\u0647\u0631\u060c \u0628\u062f\u0648\u0646 \u0627\u0633\u062a\u062b\u0646\u0627\u0621.\n\n---\n\n\u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u0645\u0648 \u0641\u064a \u0627\u0644\u0634\u062e\u0635.\n\u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u0641\u064a \u0627\u0644\u0637\u0631\u064a\u0642\u0629.\n\n\u0625\u0639\u062f\u0627\u062f \u0627\u0644\u0631\u0648\u0627\u062a\u0628 \u064a\u062f\u0648\u064a\u0627\u064b \u0641\u064a \u0634\u0631\u0643\u0629 \u0641\u064a\u0647\u0627 \u0663\u0660 \u0645\u0648\u0638\u0641\u0627\u064b \u064a\u0623\u0643\u0644 \u0641\u064a \u0627\u0644\u0645\u0639\u062f\u0644 \u0666 \u0625\u0644\u0649 \u0661\u0662 \u0633\u0627\u0639\u0629 \u0643\u0644 \u062f\u0648\u0631\u0629.\n\n\u062d\u0633\u0627\u0628 \u0645\u062e\u0635\u0635 \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u062e\u062f\u0645\u0629\u061f \u0633\u0627\u0639\u0629 \u0623\u062e\u0631\u0649.\n\u0627\u0644\u062a\u062d\u0642\u0642 \u0645\u0646 \u0627\u0644\u0627\u0644\u062a\u0632\u0627\u0645\u0627\u062a \u0642\u0628\u0644 \u0631\u0641\u0639 \u0645\u0644\u0641 \u0646\u0638\u0627\u0645 \u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0623\u062c\u0648\u0631\u061f \u0633\u0627\u0639\u0629 \u062b\u0627\u0646\u064a\u0629.\n\u0627\u0643\u062a\u0634\u0627\u0641 \u062e\u0637\u0623 \u0628\u0639\u062f \u0627\u0644\u0631\u0641\u0639\u061f \u0627\u0644\u062d\u064a\u0646 \u062a\u0628\u062f\u0623 \u0645\u0646 \u0627\u0644\u0623\u0648\u0644.\n\n\u0647\u0630\u0627 \u0648\u0642\u062a \u0641\u0639\u0644\u064a\u060c \u0645\u0646 \u064a\u062f \u0645\u0648\u0638\u0641 \u062a\u062f\u0641\u0639 \u0644\u0647 \u0631\u0627\u062a\u0628\u0627\u064b.\n\n---\n\n\u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0639\u0645\u0644 \u0645\u0627 \u062a\u0642\u0628\u0644 \u0627\u0644\u0623\u0639\u0630\u0627\u0631 \u0625\u0630\u0627 \u062c\u0627\u0621 \u0627\u0644\u0645\u0644\u0641 \u0646\u0627\u0642\u0635\u0627\u064b.\n\u0635\u0646\u062f\u0648\u0642 \u0627\u0644\u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u0629 \u0645\u0627 \u064a\u064f\u0645\u062f\u0651\u062f \u0627\u0644\u0645\u0648\u0627\u0639\u064a\u062f.\n\u0648\u0627\u0644\u062e\u0637\u0623 \u0641\u064a \u0627\u0644\u0631\u0648\u0627\u062a\u0628 \u064a\u064f\u0643\u0644\u0651\u0641\u0643 \u0623\u0643\u062b\u0631 \u0645\u0646 \u0627\u0644\u0648\u0642\u062a \u2014 \u064a\u064f\u0643\u0644\u0651\u0641\u0643 \u0627\u0644\u062b\u0642\u0629.\n\n---\n\nSmartPRO Hub \u064a\u062c\u0645\u0639 \u0627\u0644\u0631\u0648\u0627\u062a\u0628 \u0648\u0646\u0638\u0627\u0645 \u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0623\u062c\u0648\u0631 \u0648\u062d\u0633\u0627\u0628\u0627\u062a \u0635\u0646\u062f\u0648\u0642 \u0627\u0644\u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u0629 \u0641\u064a \u0645\u0646\u0635\u0629 \u0648\u0627\u062d\u062f\u0629\u060c \u0645\u0631\u062a\u0628\u0637\u0629 \u0645\u0628\u0627\u0634\u0631\u0629\u064b \u0628\u0627\u0644\u0628\u0646\u0643.\n\n\u062e\u0644\u0627\u0635\u060c \u0645\u0627 \u0641\u064a \u0