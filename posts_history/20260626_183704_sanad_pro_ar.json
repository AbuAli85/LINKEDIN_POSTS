{
  "pillar": "sanad_pro_ar",
  "topic": "\u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0644\u0627 \u064a\u0633\u062a\u0637\u064a\u0639 \u0635\u0627\u062d\u0628\u0647 \u0623\u062e\u0630 \u0623\u0633\u0628\u0648\u0639 \u0625\u062c\u0627\u0632\u0629 \u0644\u0623\u0646 \u0643\u0644 \u0627\u0644\u0639\u0645\u0644\u064a\u0629 \u0645\u0648\u062c\u0648\u062f\u0629 \u0641\u064a \u0631\u0623\u0633\u0647",
  "format": "\u0627\u0643\u062a\u0628 \u0642\u0627\u0626\u0645\u0629 \u0645\u0631\u0642\u0651\u0645\u0629 \u0645\u0646 \u0665 \u0639\u0644\u0627\u0645\u0627\u062a \u062a\u062f\u0644 \u0639\u0644\u0649 \u0623\u0646 \u0645\u0643\u062a\u0628 \u0627\u0644\u0633\u0646\u062f \u0642\u062f \u062a\u062c\u0627\u0648\u0632 \u0637\u0627\u0642\u062a\u0647 \u0627\u0644\u062d\u0627\u0644\u064a\u0629 \u2014 \u0643\u0646 \u0645\u062d\u062f\u062f\u0627\u064b \u0628\u0645\u0627 \u064a\u0643\u0641\u064a \u0644\u064a\u062a\u0639\u0631\u0641 \u0645\u0639\u0638\u0645 \u0627\u0644\u0642\u0631\u0627\u0621 \u0639\u0644\u0649 \u0623\u0631\u0628\u0639 \u0645\u0646\u0647\u0627",
  "language": "ar",
  "segment": "A",
  "publish_day": "Tuesday",
  "post": "\u062e\u0645\u0633 \u0639\u0644\u0627\u0645\u0627\u062a \u062a\u062f\u0644 \u0639\u0644\u0649 \u0623\u0646 \u0645\u0643\u062a\u0628 \u0627\u0644\u0633\u0646\u062f \u062a\u062c\u0627\u0648\u0632 \u0637\u0627\u0642\u062a\u0647 \u0627\u0644\u062a\u0634\u063a\u064a\u0644\u064a\u0629 \u2014 \u0648\u0623\u0646\u062a \u0644\u0627 \u062a\u0633\u062a\u0637\u064a\u0639 \u0623\u062e\u0630 \u0625\u062c\u0627\u0632\u0629 \u0623\u0633\u0628\u0648\u0639:\n\n\u0661. \u062a\u0648\u0627\u0631\u064a\u062e \u0627\u0646\u062a\u0647\u0627\u0621 \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0645\u062e\u0632\u0651\u0646\u0629 \u0641\u064a \u0631\u0623\u0633\u0643 \u2014 \u0644\u0627 \u0641\u064a \u0646\u0638\u0627\u0645 \u064a\u064f\u0646\u0628\u0651\u0647\u0643.\n\u0662. \u0639\u0646\u062f\u0645\u0627 \u064a\u0633\u0623\u0644\u0643 \u0639\u0645\u064a\u0644 \u0639\u0646 \u062d\u0627\u0644\u0629 \u0637\u0644\u0628\u0647\u060c \u062a\u0628\u062d\u062b \u0641\u064a \u062b\u0644\u0627\u062b \u0645\u062c\u0645\u0648\u0639\u0627\u062a \u0648\u0627\u062a\u0633\u0627\u0628 \u0642\u0628\u0644 \u0623\u0646 \u062a\u064f\u062c\u064a\u0628.\n\u0663. \u0622\u062e\u0631 \u0645\u0631\u0629 \u0623\u062d\u0636\u0631\u062a \u0641\u064a\u0647\u0627 \u0645\u0648\u0638\u0641\u0627\u064b \u062c\u062f\u064a\u062f\u0627\u064b\u060c \u0623\u0645\u0636\u064a\u062a \u064a\u0648\u0645\u064a\u0646 \u062a\u0634\u0631\u062d \u0644\u0647 \"\u0643\u064a\u0641 \u062a\u0633\u064a\u0631 \u0627\u0644\u0623\u0645\u0648\u0631\" \u2014 \u0644\u0623\u0646 \u0644\u0627 \u0634\u064a\u0621 \u0645\u062f\u0648\u0651\u0646 \u0641\u064a \u0623\u064a \u0645\u0643\u0627\u0646.\n\u0664. \u0645\u0644\u0641 \u0627\u0644\u0625\u0643\u0633\u0644 \u0627\u0644\u0630\u064a \u064a\u062a\u062a\u0628\u0639 \u0661\u0665 \u062a\u0623\u0634\u064a\u0631\u0629 \u0625\u0642\u0627\u0645\u0629 \u0648\u0664\u0660 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u0644\u0640\u0662\u0660 \u0634\u0631\u0643\u0629 \u2014 \u0623\u0646\u062a \u0648\u062d\u062f\u0643 \u062a\u0639\u0631\u0641 \u0643\u064a\u0641 \u062a\u0642\u0631\u0623\u0647.\n\u0665. \u0641\u0643\u0631\u0629 \u063a\u064a\u0627\u0628\u0643 \u0623\u0633\u0628\u0648\u0639\u0627\u064b \u062a\u064f\u0642\u0644\u0642 \u0639\u0645\u0644\u0627\u0621\u0643 \u0642\u0628\u0644 \u0623\u0646 \u062a\u064f\u0642\u0644\u0642\u0643 \u0623\u0646\u062a.\n\n---\n\n\u0647\u0630\u0647 \u0644\u064a\u0633\u062a \u0645\u0634\u0643\u0644\u0629 \u0648\u0642\u062a. \u0647\u0630\u0647 \u0645\u0634\u0643\u0644\u0629 \u0628\u0646\u064a\u0629.\n\n\u062d\u064a\u0646 \u062a\u0643\u0648\u0646 \u0627\u0644\u0639\u0645\u0644\u064a\u0629 \u0643\u0644\u0647\u0627 \u0641\u064a \u0631\u0623\u0633 \u0634\u062e\u0635 \u0648\u0627\u062d\u062f\u060c \u0627\u0644\u0634\u0631\u0643\u0629 \u0644\u0627 \u062a\u0646\u0645\u0648 \u2014 \u0647\u064a \u062a\u0639\u062a\u0645\u062f \u0639\u0644\u0649 \u062d\u0636\u0648\u0631 \u0630\u0644\u0643 \u0627\u0644\u0634\u062e\u0635 \u0643\u0644 \u064a\u0648\u0645 \u062f\u0648\u0646 \u0627\u0633\u062a\u062b\u0646\u0627\u0621.\n\n\u0669\u0662\u0664 \u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0645\u0631\u062e\u0635 \u0641\u064a \u0639\u064f\u0645\u0627\u0646. \u0645\u0639\u0638\u0645\u0647\u0627 \u064a\u064f\u062f\u064a\u0631 \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0648\u062a\u0623\u0634\u064a\u0631\u0627\u062a \u0627\u0644\u0625\u0642\u0627\u0645\u0629 \u0648\u062a\u0633\u062c\u064a\u0644\u0627\u062a \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0639\u0645\u0644 \u0639\u0628\u0631 \u0645\u062c\u0645\u0648\u0639\u0627\u062a \u0648\u0627\u062a\u0633\u0627\u0628 \u0648\u0631\u0633\u0627\u0626\u0644 \u0645\u062a\u0641\u0631\u0642\u0629 \u0648\u0645\u0644\u0641\u0627\u062a \u0644\u0627 \u064a\u0641\u0647\u0645\u0647\u0627 \u0633\u0648\u0649 \u0645\u0646 \u0628\u0646\u0627\u0647\u0627.\n\n\u0627\u0644\u0633\u0642\u0641 \u0627\u0644\u062a\u0634\u063a\u064a\u0644\u064a \u0644\u0627 \u064a\u0623\u062a\u064a \u0645\u0646 \u0646\u0642\u0635 \u0627\u0644\u0639\u0645\u0644\u0627\u0621. \u064a\u0623\u062a\u064a \u0645\u0646 \u0627\u0644\u0644\u062d\u0638\u0629 \u0627\u0644\u062a\u064a \u062a\u0635\u0628\u062d \u0641\u064a\u0647\u0627 \u0623\u0646\u062a \u0627\u0644\u0648\u062d\u064a\u062f \u0627\u0644\u0630\u064a \u064a\u0639\u0631\u0641 \u0623\u064a\u0646 \u0643\u0644 \u0634\u064a\u0621.\n\n---\n\n\u062c\u0631\u0651\u0628 \u0645\u0633\u0627\u0639\u062f \u0633\u0646\u062f \u0627\u0644\u0630\u0643\u064a \u0645\u062c\u0627\u0646\u0627\u064b \u2014 \u0625\u062c\u0627\u0628\u0627\u062a \u0641\u0648\u0631\u064a\u0629 \u0639\u0646 \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0648\u062a\u0623\u0634\u064a\u0631\u0627\u062a \u0627\u0644\u0625\u0642\u0627\u0645\u0629 \u0648\u0627\u0644\u0631\u0633\u0648\u0645 \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629:\nhttps://www.thesmartpro.io/sanad/assistant?utm_source=linkedin&utm_medium=social&utm_campaign=sanad-pro-ar\n\n\u0643\u0645 \u064a\u0648\u0645\u0627\u064b \u0645\u0631\u0651\u062a \u0645\u0646\u0630 \u0622\u062e\u0631 \u0645\u0631\u0629 \u0623\u062e\u0630\u062a \u0641\u064a\u0647\u0627 \u0625\u062c\u0627\u0632\u0629 \u062d\u0642\u064a\u0642\u064a\u0629 \u062f\u0648\u0646 \u0623\u0646 \u062a\u0641\u062a\u062d \u0648\u0627\u062a\u0633\u0627\u0628\u061f\n\n#OmanBusiness\n#HRManagement\n#PayrollOman\n#WPS\n#SmartPROHub\n#Omanization\n#GCCBusiness",
