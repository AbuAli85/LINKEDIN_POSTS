{
  "pillar": "sanad_pro_ar",
  "topic": "\u0625\u062f\u062e\u0627\u0644 \u0635\u0648\u062a\u064a \u0628\u0627\u0644\u0644\u0647\u062c\u0629 \u0627\u0644\u0639\u064f\u0645\u0627\u0646\u064a\u0629. \u0628\u062d\u062b \u0641\u0648\u0631\u064a \u0641\u064a \u0627\u0644\u0631\u0633\u0648\u0645 \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629. \u0645\u0637\u0627\u0628\u0642\u0629 \u0645\u0639 \u0623\u0642\u0631\u0628 \u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0645\u0631\u062e\u0635. \u0639\u0631\u0636 \u0633\u0639\u0631 \u0643\u0627\u0645\u0644. \u0645\u062c\u0627\u0646\u064a. \u0628\u062f\u0648\u0646 \u062a\u0633\u062c\u064a\u0644. \u0647\u0630\u0627 \u0645\u0633\u0627\u0639\u062f \u0633\u0646\u062f \u0627\u0644\u0630\u0643\u064a \u0639\u0644\u0649 www.thesmartpro.io/sanad/assistant",
  "format": "\u0627\u0643\u062a\u0628 \u0642\u0627\u0626\u0645\u0629 \u0645\u0631\u0642\u0651\u0645\u0629 \u0645\u0646 \u0665 \u0639\u0644\u0627\u0645\u0627\u062a \u062a\u062f\u0644 \u0639\u0644\u0649 \u0623\u0646 \u0645\u0643\u062a\u0628 \u0627\u0644\u0633\u0646\u062f \u0642\u062f \u062a\u062c\u0627\u0648\u0632 \u0637\u0627\u0642\u062a\u0647 \u0627\u0644\u062d\u0627\u0644\u064a\u0629 \u2014 \u0643\u0646 \u0645\u062d\u062f\u062f\u0627\u064b \u0628\u0645\u0627 \u064a\u0643\u0641\u064a \u0644\u064a\u062a\u0639\u0631\u0641 \u0645\u0639\u0638\u0645 \u0627\u0644\u0642\u0631\u0627\u0621 \u0639\u0644\u0649 \u0623\u0631\u0628\u0639 \u0645\u0646\u0647\u0627",
  "language": "ar",
  "segment": "A",
  "publish_day": "Tuesday",
  "post": "\u0665 \u0639\u0644\u0627\u0645\u0627\u062a \u062a\u0643\u0634\u0641 \u0623\u0646 \u0645\u0643\u062a\u0628\u0643 \u062a\u062c\u0627\u0648\u0632 \u0637\u0627\u0642\u062a\u0647 \u0627\u0644\u0641\u0639\u0644\u064a\u0629 \u2014 \u0648\u0644\u064a\u0633 \u0637\u0627\u0642\u062a\u0647 \u0627\u0644\u0645\u064f\u0639\u0644\u0646\u0629:\n\n\u0661. \u062a\u062a\u0630\u0643\u0631 \u0645\u0648\u0639\u062f \u062a\u062c\u062f\u064a\u062f \u062a\u0635\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0645\u0646 \u0631\u0623\u0633\u0643 \u2014 \u0644\u0627 \u0645\u0646 \u0646\u0638\u0627\u0645 \u064a\u0630\u0643\u0651\u0631\u0643.\n\u0662. \u0645\u0639\u0631\u0641\u0629 \u0631\u0633\u0648\u0645 \u0645\u0639\u0627\u0645\u0644\u0629 \u062c\u062f\u064a\u062f\u0629 \u062a\u0628\u062f\u0623 \u0628\u0627\u062a\u0635\u0627\u0644 \u0647\u0627\u062a\u0641\u064a \u0623\u0648 \u062a\u0642\u0644\u064a\u0628 \u0641\u064a \u0645\u062d\u0627\u062f\u062b\u0627\u062a \u0642\u062f\u064a\u0645\u0629.\n\u0663. \u0644\u062f\u064a\u0643 \u0645\u0644\u0641 \u0625\u0643\u0633\u0644 \"\u0646\u0647\u0627\u0626\u064a\" \u2014 \u0648\u0628\u062c\u0627\u0646\u0628\u0647 \u0645\u0644\u0641 \u0622\u062e\u0631 \u0627\u0633\u0645\u0647 \"\u0646\u0647\u0627\u0626\u064a \u0641\u0639\u0644\u0627\u064b\".\n\u0664. \u0627\u0644\u0639\u0645\u064a\u0644 \u064a\u0633\u0623\u0644\u0643 \u0639\u0646 \u062d\u0627\u0644\u0629 \u0645\u0639\u0627\u0645\u0644\u062a\u0647 \u0642\u0628\u0644 \u0623\u0646 \u062a\u0628\u0627\u062f\u0631 \u0623\u0646\u062a \u0628\u0627\u0644\u0633\u0624\u0627\u0644.\n\u0665. \u0623\u0642\u0631\u0628 \u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0645\u0631\u062e\u0635 \u0644\u0639\u0645\u064a\u0644\u0643 \u0627\u0644\u062c\u062f\u064a\u062f \u2014 \u0644\u0627 \u062a\u0645\u0644\u0643 \u0625\u062c\u0627\u0628\u0629 \u0641\u0648\u0631\u064a\u0629.\n\n\u0625\u0630\u0627 \u062a\u0639\u0631\u0651\u0641\u062a \u0639\u0644\u0649 \u0623\u0631\u0628\u0639 \u0645\u0646\u0647\u0627\u060c \u0641\u0627\u0644\u0645\u0633\u0623\u0644\u0629 \u0644\u064a\u0633\u062a \u0641\u064a \u0643\u0641\u0627\u0621\u062a\u0643. \u0627\u0644\u0645\u0633\u0623\u0644\u0629 \u0641\u064a \u0627\u0644\u0623\u062f\u0648\u0627\u062a.\n\n\u0645\u0633\u0627\u0639\u062f \u0633\u0646\u062f \u0627\u0644\u0630\u0643\u064a \u0645\u062c\u0627\u0646\u064a \u2014 \u0644\u0627 \u062a\u0633\u062c\u064a\u0644\u060c \u0644\u0627 \u0627\u0646\u062a\u0638\u0627\u0631. \u0627\u0643\u062a\u0628 \u0623\u0648 \u062a\u0643\u0644\u0645 \u0628\u0627\u0644\u0639\u0631\u0628\u064a\u0629\u060c \u0648\u062a\u062d\u0635\u0644 \u0641\u0648\u0631\u0627\u064b \u0639\u0644\u0649: \u0631\u0633\u0648\u0645 \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0639\u0645\u0644 \u0627\u0644\u0631\u0633\u0645\u064a\u0629\u060c \u0623\u0642\u0631\u0628 \u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0645\u0631\u062e\u0635 \u0628\u062d\u0633\u0628 \u0627\u0644\u0645\u062d\u0627\u0641\u0638\u0629\u060c \u0648\u0639\u0631\u0636 \u0633\u0639\u0631 \u0643\u0627\u0645\u0644 \u064a\u0634\u0645\u0644 \u0627\u0644\u0631\u0633\u0648\u0645 \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629 \u0648\u0631\u0633\u0648\u0645 \u0627\u0644\u0645\u0643\u062a\u0628.\n\n\u0645\u0646 \u064a\u062a\u0627\u0628\u0639 \u0645\u0639\u0627\u0645\u0644\u0627\u062a \u0662\u0660 \u0634\u0631\u0643\u0629 \u064a\u0639\u0631\u0641 \u0643\u0645 \u062f\u0642\u064a\u0642\u0629 \u062a\u0636\u064a\u0639 \u0641\u064a \u0633\u0624\u0627\u0644 \u0648\u0627\u062d\u062f \u0639\u0646 \u0631\u0633\u0648\u0645 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u0623\u0648 \u062a\u0623\u0634\u064a\u0631\u0629 \u0625\u0642\u0627\u0645\u0629.\n\n\u062c\u0631\u0651\u0628 \u0645\u0633\u0627\u0639\u062f \u0633\u0646\u062f \u0627\u0644\u0630\u0643\u064a \u0645\u062c\u0627\u0646\u0627\u064b \u2014 \u0625\u062c\u0627\u0628\u0627\u062a \u0641\u0648\u0631\u064a\u0629 \u0639\u0646 \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0648\u0627\u0644\u062a\u0623\u0634\u064a\u0631\u0627\u062a \u0648\u0627\u0644\u0631\u0633\u0648\u0645 \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629:\nhttps://www.thesmartpro.io/sanad/assistant?utm_source=linkedin&utm_medium=social&utm_campaign=sanad-pro-ar\n\n\u0623\u064a\u0651 \u0627\u0644\u0639\u0644\u0627\u0645\u0627\u062a \u0627\u0644\u062e\u0645\u0633 \u062a\u0631\u0627\u0647\u0627 \u0623\u0643\u062b\u0631 \u0641\u064a \u0639\u0645\u0644\u0643 \u0627\u0644\u064a\u0648\u0645\u064a\u061f\n\n#OmanBusiness\n#HRManagement\n#SmartPROHub\n#Omanization\n#GCCBusiness",
