{
  "pillar": "sanad_pro_ar",
  "segment": "arabic_audience",
  "hook": "story",
  "hook_text": "\u0642\u0627\u0644\u062a \u0645\u062f\u064a\u0631\u0629 \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0628\u0634\u0631\u064a\u0629: \u00ab\u0644\u0627 \u0623\u0639\u0631\u0641 \u0643\u0645 \u0639\u0627\u0645\u0644\u0627\u064b \u0644\u062f\u064a\u0646\u0627 \u0641\u064a \u0633\u0646\u0627\u062f \u0628\u0627\u0644\u0636\u0628\u0637\u00bb. \u0648\u0643\u0627\u0646 \u0627\u0644\u062c\u0648\u0627\u0628 \u0645\u0641\u0627\u062c\u0623\u0629.",
  "body": "\u0634\u0631\u0643\u0629 \u0645\u0642\u0627\u0648\u0644\u0627\u062a. \u0667\u0664 \u0639\u0627\u0645\u0644\u0627\u064b \u0645\u0633\u062c\u0644\u0627\u064b \u0641\u064a \u0627\u0644\u0639\u0642\u062f.\n\n\u0637\u0644\u0628\u0646\u0627 \u0645\u0646\u0647\u0627: \u0643\u0645 \u0645\u0646\u0647\u0645 \u0646\u0634\u0637 \u0641\u0639\u0644\u0627\u064b \u0641\u064a \u0633\u0646\u0627\u062f \u0627\u0644\u0622\u0646\u061f\n\n\u062a\u0648\u0642\u0641\u062a. \u0641\u062a\u062d\u062a \u0645\u0644\u0641 Excel. \u0642\u0644\u0651\u0628\u062a \u0628\u064a\u0646 \u0627\u0644\u0623\u0648\u0631\u0627\u0642.\n\n\u0628\u0639\u062f \u0668 \u062f\u0642\u0627\u0626\u0642: \u00ab\u0631\u0628\u0645\u0627 \u0666\u0668\u061f \u0644\u0633\u062a \u0645\u062a\u0623\u0643\u062f\u0629\u00bb.\n\n\u0641\u062a\u062d\u0646\u0627 SmartPRO Hub \u0645\u0639\u0647\u0627.\n\n\u0646\u0642\u0631\u0629 \u0648\u0627\u062d\u062f\u0629 \u0639\u0644\u0649 \u062a\u0642\u0631\u064a\u0631 \u0633\u0646\u0627\u062f.\n\n\u0627\u0644\u0646\u062a\u064a\u062c\u0629: \u0667\u0661 \u0646\u0634\u0637\u0627\u064b\u060c \u0648\u0662 \u0645\u0646\u062a\u0647\u064a\u0627\u0646 \u0648\u063a\u064a\u0631 \u0645\u062d\u0648\u0651\u0644\u064a\u0646\u060c \u0648\u0661 \u0627\u0646\u062a\u0647\u062a \u062a\u0623\u0634\u064a\u0631\u062a\u0647 \u0645\u0646\u0630 \u0663 \u0623\u0634\u0647\u0631.\n\n\u0644\u064a\u0633 \u0666\u0668\u060c \u0648\u0644\u064a\u0633 \u0667\u0664. \u0628\u0644 \u0667\u0661 \u0646\u0634\u0637\u0627\u064b \u2014 \u0645\u0639 \u0645\u0634\u0643\u0644\u0627\u062a \u0641\u064a \u0663 \u0645\u0646\u0647\u0645 \u062a\u062a\u0637\u0644\u0628 \u0625\u062c\u0631\u0627\u0621\u064b \u0641\u0648\u0631\u064a\u0627\u064b.\n\n\u0631\u062f\u0651\u062a: \u00ab\u0623\u064a \u0623\u0646\u0647 \u0643\u0627\u0646 \u0644\u062f\u064a\u0651 \u0639\u0627\u0645\u0644 \u0628\u062a\u0623\u0634\u064a\u0631\u0629 \u0645\u0646\u062a\u0647\u064a\u0629 \u0645\u0646\u0630 \u062b\u0644\u0627\u062b\u0629 \u0623\u0634\u0647\u0631 \u062f\u0648\u0646 \u0623\u0646 \u0623\u0639\u0644\u0645\u061f\u00bb\n\n\u0646\u0639\u0645\u060c \u0647\u0630\u0627 \u0628\u0627\u0644\u0636\u0628\u0637.\n\n\u0627\u0644\u063a\u0631\u0627\u0645\u0629 \u0639\u0644\u0649 \u0627\u0644\u0639\u0627\u0645\u0644 \u063a\u064a\u0631 \u0627\u0644\u0645\u0648\u062b\u0651\u0642 \u062a\u0628\u062f\u0623 \u0645\u0646 \u0662\u0660\u0660 \u0631\u064a\u0627\u0644 \u0639\u064f\u0645\u0627\u0646\u064a.\n\n\u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u0644\u064a\u0633\u062a \u0627\u0644\u0625\u0647\u0645\u0627\u0644\u060c \u0628\u0644 \u0623\u0646 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0643\u0627\u0646\u062a \u0645\u0641\u0631\u0651\u0642\u0629 \u0641\u064a \u0623\u0645\u0627\u0643\u0646 \u0645\u062e\u062a\u0644\u0641\u0629\u060c \u062f\u0648\u0646 \u0645\u0646\u0638\u0648\u0645\u0629 \u062a\u0648\u062d\u0651\u062f\u0647\u0627.",
  "cta": "\u0647\u0644 \u062a\u0639\u0631\u0641 \u0623\u0646\u062a \u0628\u0627\u0644\u0636\u0628\u0637 \u0643\u0645 \u0645\u0648\u0638\u0641\u0627\u064b \u0646\u0634\u0637\u0627\u064b \u0644\u062f\u064a\u0643 \u0641\u064a \u0633\u0646\u0627\u062f \u0627\u0644\u0622\u0646\u061f\n\u062a\u0648\u0627\u0635\u0644 \u0645\u0639\u0646\u0627: smartprohub.com",
