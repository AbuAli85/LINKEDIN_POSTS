{
  "pillar": "sanad_pro_ar",
  "topic": "\u062a\u062a\u0628\u0639 \u0645\u0648\u0627\u0639\u064a\u062f \u062a\u0633\u062c\u064a\u0644 \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0639\u0645\u0644 \u0644\u0640\u0662\u0660 \u0634\u0631\u0643\u0629 \u0639\u0645\u064a\u0644 \u0641\u064a \u0625\u0643\u0633\u0644 \u0645\u0634\u062a\u0631\u0643 \u2014 \u0645\u062a\u0649 \u0628\u0627\u0644\u0636\u0628\u0637 \u064a\u0646\u0643\u0633\u0631 \u0647\u0630\u0627\u061f",
  "format": "\u0627\u0628\u0646\u0650 \u0645\u0642\u0627\u0631\u0646\u0629 \u062d\u0627\u062f\u0629 \u0642\u0628\u0644/\u0628\u0639\u062f: \u0625\u062f\u0627\u0631\u0629 \u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629 \u0628\u0648\u0627\u062a\u0633\u0627\u0628 \u0648\u0625\u0643\u0633\u0644 \u0645\u0642\u0627\u0628\u0644 SmartPRO Hub \u2014 \u0646\u0641\u0633 \u0627\u0644\u0623\u0633\u0628\u0648\u0639\u060c \u062a\u062c\u0631\u0628\u0629 \u0645\u062e\u062a\u0644\u0641\u0629 \u062a\u0645\u0627\u0645\u0627\u064b",
  "language": "ar",
  "segment": "A",
  "publish_day": "Tuesday",
  "post": "\u0627\u0644\u0627\u062b\u0646\u064a\u0646 \u0627\u0644\u0635\u0628\u0627\u062d. \u0664\u0660 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644\u060c \u0661\u0665 \u062a\u0623\u0634\u064a\u0631\u0629 \u0625\u0642\u0627\u0645\u0629\u060c \u0668 \u062a\u0633\u062c\u064a\u0644\u0627\u062a \u0641\u064a \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0639\u0645\u0644 \u2014 \u0648\u0662\u0660 \u0634\u0631\u0643\u0629 \u0639\u0645\u064a\u0644 \u062a\u0646\u062a\u0638\u0631.\n\n\u0643\u0644 \u0647\u0630\u0627 \u0641\u064a \u0645\u0644\u0641 \u0625\u0643\u0633\u0644 \u0648\u0627\u062d\u062f \u0645\u0634\u062a\u0631\u0643.\n\n---\n\n\u0623\u0639\u0631\u0641 \u0647\u0630\u0627 \u0627\u0644\u0645\u0634\u0647\u062f. \u0625\u0643\u0633\u0644 \u0627\u0644\u0645\u0648\u0627\u0639\u064a\u062f \u0645\u0641\u062a\u0648\u062d \u0639\u0644\u0649 \u0634\u0627\u0634\u0629\u060c \u0648\u0645\u062c\u0645\u0648\u0639\u0627\u062a \u0648\u0627\u062a\u0633\u0627\u0628 \u062a\u062a\u0631\u0627\u0643\u0645 \u0639\u0644\u0649 \u0627\u0644\u0623\u062e\u0631\u0649. \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u064a\u0646\u062a\u0647\u064a \u0627\u0644\u0623\u0633\u0628\u0648\u0639 \u0627\u0644\u0642\u0627\u062f\u0645 \u2014 \u0648\u0644\u0627 \u0623\u062d\u062f \u0645\u062a\u0623\u0643\u062f \u0625\u0646 \u0643\u0627\u0646 \u0627\u0644\u0639\u0645\u064a\u0644 \u0623\u064f\u0628\u0644\u063a \u0623\u0635\u0644\u0627\u064b.\n\n\u062b\u0645 \u064a\u062a\u0635\u0644 \u0628\u0643 \u0627\u0644\u0639\u0645\u064a\u0644 \u0642\u0628\u0644 \u0633\u0641\u0631 \u0645\u0648\u0638\u0641\u0647 \u0628\u064a\u0648\u0645\u064a\u0646.\n\n\u0627\u0644\u0625\u0643\u0633\u0644 \u0644\u0627 \u064a\u0646\u0643\u0633\u0631 \u0641\u062c\u0623\u0629. \u064a\u0646\u0643\u0633\u0631 \u062d\u064a\u0646 \u064a\u0635\u0628\u062d \u0627\u0644\u0639\u0645\u064a\u0644 \u0627\u0644\u062a\u0627\u0644\u064a \u0623\u0643\u0628\u0631 \u0645\u0646 \u0623\u0646 \u062a\u062a\u0627\u0628\u0639\u0647 \u0628\u0627\u0644\u0637\u0631\u064a\u0642\u0629 \u0630\u0627\u062a\u0647\u0627.\n\n---\n\n\u0627\u0644\u0623\u0633\u0628\u0648\u0639 \u0646\u0641\u0633\u0647\u060c \u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0622\u062e\u0631 \u064a\u062f\u064a\u0631 \u0662\u0660 \u0634\u0631\u0643\u0629 \u0639\u0645\u064a\u0644 \u0639\u0628\u0631 SmartPRO Hub:\n\n\u0643\u0644 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u0644\u0647 \u062a\u0627\u0631\u064a\u062e \u0627\u0646\u062a\u0647\u0627\u0621 \u0645\u0631\u0626\u064a. \u0627\u0644\u062a\u0646\u0628\u064a\u0647 \u064a\u0635\u0644 \u0642\u0628\u0644 \u0663\u0660 \u064a\u0648\u0645\u0627\u064b. \u0628\u0648\u0627\u0628\u0629 \u0627\u0644\u0639\u0645\u064a\u0644 \u062a\u064f\u0638\u0647\u0631 \u0644\u0647 \u062d\u0627\u0644\u0629 \u0637\u0644\u0628\u0647 \u2014 \u062f\u0648\u0646 \u0631\u0633\u0627\u0644\u0629 \u0648\u0627\u062a\u0633\u0627\u0628 \u0648\u0627\u062d\u062f\u0629.\n\n\u0644\u0627 \u0641\u0648\u0636\u0649. \u0646\u0641\u0633 \u0627\u0644\u0645\u0639\u0627\u0645\u0644\u0627\u062a. \u062a\u062c\u0631\u0628\u0629 \u0645\u062e\u062a\u0644\u0641\u0629 \u062a\u0645\u0627\u0645\u0627\u064b.\n\n---\n\n\u0627\u0644\u0633\u0642\u0641 \u0627\u0644\u062a\u0634\u063a\u064a\u0644\u064a \u0627\u0644\u062d\u0642\u064a\u0642\u064a \u0644\u064a\u0633 \u0639\u062f\u062f \u0627\u0644\u0639\u0645\u0644\u0627\u0621 \u2014 \u0628\u0644 \u0639\u062f\u062f \u0627\u0644\u0645\u0648\u0627\u0639\u064a\u062f \u0627\u0644\u062a\u064a \u062a\u0633\u062a\u0637\u064a\u0639 \u062a\u062a\u0628\u0639\u0647\u0627 \u0628\u0630\u0627\u0643\u0631\u062a\u0643 \u0648\u0645\u0644\u0641 \u0648\u0627\u062d\u062f.\n\n---\n\n\u062c\u0631\u0651\u0628 \u0645\u0633\u0627\u0639\u062f \u0633\u0646\u062f \u0627\u0644\u0630\u0643\u064a \u0645\u062c\u0627\u0646\u0627\u064b \u2014 \u0625\u062c\u0627\u0628\u0627\u062a \u0641\u0648\u0631\u064a\u0629 \u0639\u0646 \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0648\u0627\u0644\u062a\u0623\u0634\u064a\u0631\u0627\u062a \u064