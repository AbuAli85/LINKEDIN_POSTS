{
  "pillar": "pain_ar",
  "topic": "\u0643\u0644 \u0639\u0645\u0644\u064a\u0629 \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u0641\u064a \u0634\u0631\u0643\u062a\u0643 \u0645\u0648\u062c\u0648\u062f\u0629 \u0641\u064a \u0630\u0647\u0646 \u0634\u062e\u0635 \u0648\u0627\u062d\u062f \u2014 \u0645\u0627\u0630\u0627 \u064a\u062d\u062f\u062b \u062d\u064a\u0646 \u064a\u0643\u0648\u0646 \u063a\u064a\u0631 \u0645\u062a\u0627\u062d\u061f",
  "format": "\u0627\u0641\u062a\u062d \u0628\u0633\u0624\u0627\u0644 \u064a\u064f\u062c\u0628\u0631 \u0627\u0644\u0642\u0627\u0631\u0626 \u0639\u0644\u0649 \u062d\u0633\u0627\u0628 \u0625\u062c\u0627\u0628\u062a\u0647 \u0627\u0644\u062e\u0627\u0635\u0629 \u2014 \u0627\u0644\u0648\u0642\u062a \u0627\u0644\u0636\u0627\u0626\u0639\u060c \u0627\u0644\u0645\u0627\u0644 \u0627\u0644\u0645\u0647\u062f\u0631\u060c \u0627\u0644\u0645\u062e\u0627\u0637\u0631 \u0627\u0644\u0645\u062d\u0645\u0648\u0644\u0629",
  "language": "ar",
  "segment": "A",
  "publish_day": "Sunday",
  "post": "\u0643\u0645 \u0634\u062e\u0635\u0627\u064b \u0641\u064a \u0634\u0631\u0643\u062a\u0643 \u064a\u0639\u0631\u0641 \u0645\u062a\u0649 \u062a\u0646\u062a\u0647\u064a \u062a\u0623\u0634\u064a\u0631\u0629 \u0625\u0642\u0627\u0645\u0629 \u0645\u0648\u0638\u0641\u0643 \u0627\u0644\u0623\u0647\u0645\u061f\n\n\u0625\u0630\u0627 \u0643\u0627\u0646 \u0627\u0644\u062c\u0648\u0627\u0628 \u0648\u0627\u062d\u062f\u0627\u064b \u0641\u0642\u0637 \u2014 \u0641\u0623\u0646\u062a \u0644\u0627 \u062a\u064f\u062f\u064a\u0631 \u0645\u0648\u0627\u0631\u062f \u0628\u0634\u0631\u064a\u0629\u060c \u0623\u0646\u062a \u062a\u064f\u062f\u064a\u0631 \u0645\u062e\u0627\u0637\u0631\u0629.\n\n\u0647\u0630\u0627 \u0644\u064a\u0633 \u0627\u0641\u062a\u0631\u0627\u0636\u0627\u064b. \u0645\u062f\u064a\u0631 \u0645\u0648\u0627\u0631\u062f \u0628\u0634\u0631\u064a\u0629 \u0623\u062e\u0630 \u0625\u062c\u0627\u0632\u0629 \u0645\u0631\u0636\u064a\u0629 \u0645\u0641\u0627\u062c\u0626\u0629 \u0641\u064a \u0627\u0644\u0623\u0633\u0628\u0648\u0639 \u0627\u0644\u0623\u0648\u0644 \u0645\u0646 \u0627\u0644\u0634\u0647\u0631. \u0645\u0648\u0639\u062f \u062a\u0634\u063a\u064a\u0644 \u0646\u0638\u0627\u0645 \u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0623\u062c\u0648\u0631 \u0643\u0627\u0646 \u064a\u0648\u0645 \u0627\u0644\u062e\u0627\u0645\u0633. \u0644\u0645 \u064a\u0639\u0631\u0641 \u0623\u062d\u062f \u0623\u064a\u0646 \u0645\u0644\u0641 \u0643\u0634\u0641 \u0627\u0644\u0631\u0648\u0627\u062a\u0628\u060c \u0648\u0644\u0627 \u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u062d\u0633\u0627\u0628\u0627\u062a \u0627\u0644\u0645\u0635\u0631\u0641\u064a\u0629\u060c \u0648\u0644\u0627 \u0645\u0646 \u064a\u062a\u0635\u0644 \u0628\u0647 \u0641\u064a \u0627\u0644\u0628\u0646\u0643.\n\n\u0627\u0644\u062e\u0637\u0623 \u0644\u0645 \u064a\u0643\u0646 \u0641\u064a \u0627\u0644\u0645\u0648\u0638\u0641. \u0627\u0644\u062e\u0637\u0623 \u0643\u0627\u0646 \u0641\u064a \u063a\u064a\u0627\u0628 \u0627\u0644\u0646\u0638\u0627\u0645.\n\n\u062d\u064a\u0646 \u062a\u0643\u0648\u0646 \u0627\u0644\u0631\u0648\u0627\u062a\u0628 \u0648\u0627\u0645\u062a\u062b\u0627\u0644 \u0635\u0646\u062f\u0648\u0642 \u0627\u0644\u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u0629 \u0648\u062a\u062a\u0628\u0639 \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0645\u062d\u0645\u0648\u0644\u0629\u064b \u0641\u064a \u0630\u0647\u0646 \u0634\u062e\u0635 \u0648\u0627\u062d\u062f\u060c \u0641\u0625\u0646 \u0623\u064a \u063a\u064a\u0627\u0628 \u2014 \u0645\u0647\u0645\u0627 \u0643\u0627\u0646 \u0645\u0628\u0631\u0631\u0647 \u2014 \u064a\u062a\u062d\u0648\u0644 \u0625\u0644\u0649 \u0623\u0632\u0645\u0629.\n\nSmartPRO Hub \u064a\u062d\u0648\u0651\u0644 \u0647\u0630\u0647 \u0627\u0644\u0645\u0639\u0631\u0641\u0629 \u0627\u0644\u0645\u062a\u0641\u0631\u0642\u0629 \u0625\u0644\u0649 \u0646\u0638\u0627\u0645 \u0648\u0627\u062d\u062f: \u0627\u0644\u0631\u0648\u0627\u062a\u0628\u060c \u0648\u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644\u060c \u0648\u0645\u0644\u0641\u0627\u062a \u0627\u0644\u0627\u0645\u062a\u062b\u0627\u0644\u060c \u0648\u0639\u0642\u0648\u062f \u0627\u0644\u0639\u0645\u0644 \u0628\u0627\u0644\u062a\u0648\u0642\u064a\u0639 \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a. \u0644\u0627 \u062c\u062f\u0627\u0648\u0644 \u0648\u0631\u0642\u064a\u0629\u060c \u0644\u0627 \u0645\u062c\u0645\u0648\u0639\u0627\u062a \u0648\u0627\u062a\u0633\u0627\u0628\u060c \u0644\u0627 \u0627\u0639\u062a\u0645\u0627\u062f \u0639\u0644\u0649 \u0630\u0627\u0643\u0631\u0629 \u0641\u0631\u062f.\n\n\u0645\u0627\u0630\u0627 \u064a\u062d\u062f\u062b \u0641\u064a \u0634\u0631\u0643\u062a\u0643 \u062d\u064a\u0646 \u064a\u063a\u064a\u0628 \u0645\u0633\u0624\u0648\u0644 \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u064a\u0648\u0645\u0627\u064b \u0648\u0627\u062d\u062f\u0627\u064b\u061f \u0627\u0644\u062c\u06