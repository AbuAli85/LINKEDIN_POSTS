{
  "pillar": "pain_ar",
  "topic": "\u062d\u064a\u0646 \u064a\u0643\u0634\u0641 \u0627\u0644\u062a\u0641\u062a\u064a\u0634 \u0627\u0644\u062d\u0643\u0648\u0645\u064a \u0645\u0627 \u0643\u0627\u0646 \u0627\u0644\u0646\u0638\u0627\u0645 \u0627\u0644\u064a\u062f\u0648\u064a \u064a\u064f\u062e\u0641\u064a\u0647 \u0637\u0648\u0627\u0644 \u0647\u0630\u0627 \u0627\u0644\u0648\u0642\u062a",
  "format": "\u0627\u0641\u062a\u062d \u0628\u0644\u062d\u0638\u0629 \u0641\u0634\u0644 \u0645\u062d\u062f\u062f\u0629 \u2014 \u062a\u0627\u0631\u064a\u062e \u062d\u0642\u064a\u0642\u064a\u060c \u062a\u0643\u0644\u0641\u0629 \u062d\u0642\u064a\u0642\u064a\u0629\u060c \u0639\u0627\u0642\u0628\u0629 \u062d\u0642\u064a\u0642\u064a\u0629 \u064a\u062a\u0639\u0631\u0641 \u0639\u0644\u064a\u0647\u0627 \u0627\u0644\u0642\u0627\u0631\u0626 \u0641\u0648\u0631\u0627\u064b",
  "language": "ar",
  "segment": "A",
  "publish_day": "Sunday",
  "post": "\u0645\u0641\u062a\u0634 \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0639\u0645\u0644 \u0637\u0644\u0628 \u0633\u062c\u0644\u0627\u062a \u0627\u0644\u062d\u0636\u0648\u0631 \u0648\u0627\u0644\u0627\u0646\u0635\u0631\u0627\u0641 \u0644\u062b\u0644\u0627\u062b\u0629 \u0623\u0634\u0647\u0631.\n\u0627\u0644\u062c\u0648\u0627\u0628: \"\u0644\u062d\u0638\u0629\u060c \u0633\u0646\u064f\u0631\u0633\u0644\u0647\u0627 \u0639\u0628\u0631 \u0627\u0644\u0628\u0631\u064a\u062f \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a.\"\n\n\u0627\u0644\u0628\u062d\u062b \u0623\u062e\u0630 \u0633\u0627\u0639\u062a\u064a\u0646 \u0648\u0646\u0635\u0641\u0627\u064b.\n\u0628\u064a\u0646 \u0645\u0644\u0641\u0627\u062a Excel\u060c \u0648\u0631\u0633\u0627\u0626\u0644 \u0645\u062a\u0641\u0631\u0642\u0629\u060c \u0648\u062c\u062f\u0627\u0648\u0644 \u0648\u0631\u0642\u064a\u0629 \u0645\u0648\u0642\u0651\u0639\u0629 \u0628\u062e\u0637 \u0627\u0644\u064a\u062f.\n\n\u0627\u0644\u0633\u062c\u0644\u0627\u062a \u0648\u064f\u062c\u062f\u062a \u0641\u064a \u0627\u0644\u0646\u0647\u0627\u064a\u0629 \u2014 \u0644\u0643\u0646 \u0623\u0631\u0642\u0627\u0645\u0647\u0627 \u0644\u0645 \u062a\u062a\u0637\u0627\u0628\u0642 \u0645\u0639 \u0643\u0634\u0641 \u0627\u0644\u0631\u0648\u0627\u062a\u0628.\n\u0644\u0627 \u0623\u062d\u062f \u064a\u0639\u0631\u0641 \u0644\u0645\u0627\u0630\u0627. \u0644\u0627 \u0623\u062d\u062f \u064a\u0639\u0631\u0641 \u0645\u0646\u0630 \u0645\u062a\u0649.\n\n\u0647\u0630\u0647 \u0644\u064a\u0633\u062a \u0642\u0635\u0629 \u0625\u0647\u0645\u0627\u0644.\n\u0647\u0630\u0647 \u0642\u0635\u0629 \u0646\u0638\u0627\u0645 \u064a\u064f\u062f\u064a\u0631\u0647 \u0623\u0646\u0627\u0633 \u0645\u062c\u062a\u0647\u062f\u0648\u0646\u060c \u0644\u0643\u0646\u0647 \u0645\u064f\u0635\u0645\u064e\u0651\u0645 \u0644\u064a\u064f\u062e\u0641\u064a \u0623\u062e\u0637\u0627\u0621\u0647 \u062d\u062a\u0649 \u064a\u0623\u062a\u064a \u0645\u0646 \u064a\u0643\u0634\u0641\u0647\u0627.\n\n\u0627\u0644\u0646\u0638\u0627\u0645 \u0627\u0644\u064a\u062f\u0648\u064a \u0644\u0627 \u064a\u064f\u0646\u0628\u0651\u0647\u0643 \u062d\u064a\u0646 \u062a\u0646\u0634\u0623 \u0627\u0644\u0645\u0634\u0643\u0644\u0629.\n\u064a\u0638\u0647\u0631\u0647\u0627 \u0641\u064a \u0623\u0633\u0648\u0623 \u0644\u062d\u0638\u0629 \u2014 \u0623\u0645\u0627\u0645 \u062c\u0647\u0629 \u0631\u0633\u0645\u064a\u0629\u060c \u0623\u0648 \u062d\u064a\u0646 \u064a\u064f\u0637\u0627\u0644\u0628 \u0645\u0648\u0638\u0641 \u0628\u0645\u062e\u0635\u0635 \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u062e\u062f\u0645\u0629\u060c \u0623\u0648 \u064a\u0648\u0645 \u062a\u064f\u0631\u0641\u0636 \u062f\u0641\u0639\u0629 \u0646\u0638\u0627\u0645 \u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0623\u062c\u0648\u0631.\n\n\u0633\u0627\u0639\u062a\u0627\u0646 \u0648\u0646\u0635\u0641 \u0644\u0644\u0628\u062d\u062b. \u062b\u0645 \u0639\u062f\u0645 \u062a\u0637\u0627\u0628\u0642 \u0641\u064a \u0627\u0644\u0623\u0631\u0642\u0627\u0645. \u062b\u0645 \u062a\u0633\u0627\u0624\u0644\u0627\u062a \u0628\u0644\u0627 \u0625\u062c\u0627\u0628\u0627\u062a.\n\u0627\u0644\u062a\u0643\u0644\u0641\u0629 \u0627\u0644\u062d\u0642\u064a\u0642\u064a\u0629 \u0644\u0645 \u062a\u0643\u0646 \u0627\u0644\u063a\u0631\u0627\u0645\u0629 \u2014 \u0643\u0627\u0646\u062a \u0645\u0627 \u0627\u0643\u062a\u0634\u0641\u062a\u0647 \u0639\u0646 \u0646\u0638\u0627\u0645\u0643.\n\n\u0645\u0627\u0630\u0627 \u0633\u064a\u0638\u0647\u0631 \u0641\u064a \u0634\u0631\u0643\u062a\u0643 \u0644\u0648 \u0637\u064f\u0644\u0628\u062a \u0645\u0646\u0643 \u0647\u0630\u0647 \u0627\u0644\u0633\u062c\u0644\u0627\u062a \u063a\u062f\u0627\u064b\u061f\n\n\u0627\u062d\u062c\u0632 \u0639\u0631\u0636\u0627\u064b \u062a\u062c\u0631\u064a\u0628\u064a\u0627\u064b \u0645\u062c\u0627\u0646\u064a\u0627\u064b \u0645\u062f\u062a\u0647 \u0663\u0660 \u062f\u0642\u064a\u0642\u0629: https://thesmartpro.io/book?type=demo&utm_source=linkedin&utm_medium=social&utm_campaign=pain-ar\n\n\u0623\u0