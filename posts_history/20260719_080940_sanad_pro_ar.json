{
  "pillar": "sanad_pro_ar",
  "topic": "\u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0644\u0627 \u064a\u0633\u062a\u0637\u064a\u0639 \u0635\u0627\u062d\u0628\u0647 \u0623\u062e\u0630 \u0623\u0633\u0628\u0648\u0639 \u0625\u062c\u0627\u0632\u0629 \u0644\u0623\u0646 \u0643\u0644 \u0627\u0644\u0639\u0645\u0644\u064a\u0629 \u0645\u0648\u062c\u0648\u062f\u0629 \u0641\u064a \u0631\u0623\u0633\u0647",
  "format": "\u0633\u0650\u0631\u0652 \u0628\u0627\u0644\u062a\u0641\u0635\u064a\u0644 \u0639\u0628\u0631 \u064a\u0648\u0645 \u0643\u0627\u0645\u0644 \u0644\u0645\u062f\u064a\u0631 \u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u064a\u062a\u0627\u0628\u0639 \u0662\u0660+ \u0634\u0631\u0643\u0629 \u0639\u0645\u064a\u0644 \u0628\u062f\u0648\u0646 \u0646\u0638\u0627\u0645 \u2014 \u0643\u0644 \u062e\u0637\u0648\u0629 \u0645\u0624\u0644\u0645\u0629 \u0628\u0627\u0644\u062a\u0633\u0644\u0633\u0644",
  "language": "ar",
  "segment": "A",
  "publish_day": "Tuesday",
  "post": "\u0635\u0627\u062d\u0628 \u0645\u0643\u062a\u0628 \u0633\u0646\u062f \u0623\u062e\u0630 \u0625\u062c\u0627\u0632\u0629 \u0623\u0633\u0628\u0648\u0639\u0627\u064b \u0648\u0627\u062d\u062f\u0627\u064b \u2014 \u0639\u0627\u062f \u0644\u064a\u062c\u062f \u062b\u0644\u0627\u062b\u0629 \u062a\u0635\u0627\u0631\u064a\u062d \u0639\u0645\u0644 \u0645\u0646\u062a\u0647\u064a\u0629\u060c \u0648\u0639\u0645\u064a\u0644 \u0623\u0648\u0642\u0641 \u0627\u0644\u062a\u0639\u0627\u0648\u0646.\n\n\u0644\u0645 \u064a\u0642\u0635\u0651\u0631. \u0644\u0643\u0646 \u0643\u0644 \u0634\u064a\u0621 \u0643\u0627\u0646 \u0645\u062d\u0641\u0648\u0638\u0627\u064b \u0641\u064a \u0631\u0623\u0633\u0647 \u0641\u0642\u0637.\n\n---\n\n\u0627\u0644\u0633\u0627\u0639\u0629 \u0627\u0644\u062b\u0627\u0645\u0646\u0629 \u0635\u0628\u0627\u062d\u0627\u064b \u2014 \u064a\u0641\u062a\u062d \u0648\u0627\u062a\u0633\u0627\u0628. \u0664\u0667 \u0631\u0633\u0627\u0644\u0629 \u0645\u0646 \u0661\u0662 \u0634\u0631\u0643\u0629 \u0639\u0645\u064a\u0644. \u0633\u0624\u0627\u0644 \u0639\u0646 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644\u060c \u0648\u0633\u0624\u0627\u0644 \u0639\u0646 \u062a\u0623\u0634\u064a\u0631\u0629 \u0625\u0642\u0627\u0645\u0629\u060c \u0648\u0633\u0624\u0627\u0644 \u062b\u0627\u0644\u062b \u0639\u0646 \u0645\u0648\u0639\u062f \u062a\u0633\u062c\u064a\u0644 \u0641\u064a \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0639\u0645\u0644. \u064a\u0631\u062f \u0645\u0646 \u0627\u0644\u0630\u0627\u0643\u0631\u0629\u060c \u0644\u0623\u0646 \u0627\u0644\u0633\u062c\u0644 \u0641\u064a \u0645\u0644\u0641 \u0625\u0643\u0633\u0644 \u0639\u0644\u0649 \u062c\u0647\u0627\u0632 \u0627\u0644\u0645\u0643\u062a\u0628.\n\n\u0627\u0644\u0633\u0627\u0639\u0629 \u0627\u0644\u0639\u0627\u0634\u0631\u0629 \u2014 \u064a\u0641\u062a\u062d \u0627\u0644\u0645\u0644\u0641. \u0622\u062e\u0631 \u062a\u062d\u062f\u064a\u062b \u0642\u0628\u0644 \u0623\u0633\u0628\u0648\u0639\u064a\u0646. \u064a\u062a\u0630\u0643\u0631 \u0623\u0646 \u0625\u062d\u062f\u0649 \u0627\u0644\u0634\u0631\u0643\u0627\u062a \u0644\u062f\u064a\u0647\u0627 \u062a\u0623\u0634\u064a\u0631\u0629 \u0625\u0642\u0627\u0645\u0629 \u062a\u0646\u062a\u0647\u064a \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0634\u0647\u0631\u060c \u0644\u0643\u0646\u0647 \u0644\u0627 \u064a\u062a\u0630\u0643\u0631 \u0623\u064a\u0647\u0627. \u064a\u0628\u062f\u0623 \u064a\u062a\u0635\u0641\u062d \u0627\u0644\u0623\u0639\u0645\u062f\u0629 \u0648\u0627\u062d\u062f\u0627\u064b \u0648\u0627\u062d\u062f\u0627\u064b.\n\n\u0627\u0644\u0633\u0627\u0639\u0629 \u0627\u0644\u062b\u0627\u0646\u064a\u0629 \u0638\u0647\u0631\u0627\u064b \u2014 \u0637\u0644\u0628 \u0627\u0633\u062a\u0642\u062f\u0627\u0645 \u062c\u062f\u064a\u062f \u0644\u0634\u0631\u0643\u0629 \u0631\u0627\u0628\u0639\u0629. \u064a\u0641\u062a\u062d \u062c\u062f\u0648\u0644\u0627\u064b \u0622\u062e\u0631. \u0623\u0635\u0628\u062d\u062a \u0627\u0644\u062c\u062f\u0627\u0648\u0644 \u062b\u0644\u0627\u062b\u0629\u060c \u0643\u0644 \u0645\u0646\u0647\u0627 \u064a\u062a\u062a\u0628\u0639 \u0634\u064a\u0626\u0627\u064b \u0645\u062e\u062a\u0644\u0641\u0627\u064b.\n\n\u0627\u0644\u0633\u0627\u0639\u0629 \u0627\u0644\u0631\u0627\u0628\u0639\u0629 \u2014 \u0627\u062a\u0635\u0627\u0644 \u0645\u0646 \u0639\u0645\u064a\u0644 \u064a\u0633\u0623\u0644 \u0639\u0646 \u0641\u0627\u062a\u0648\u0631\u0629 \u062e\u062f\u0645\u0629 \u0623\u0646\u062c\u0632\u0647\u0627 \u0627\u0644\u0634\u0647\u0631 \u0627\u0644\u0645\u0627\u0636\u064a. \u064a\u0628\u062d\u062b \u0641\u064a \u0628\u0631\u064a\u062f\u0647 \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a. \u064a\u062c\u062f \u0627\u0644\u0631\u0642\u0645 \u0628\u0639\u062f \u062f\u0642\u064a\u0642\u062a\u064a\u0646.\n\n\u0647\u0630\u0627 \u064a\u0648\u0645 \u0639\u0627\u062f\u064a \u2014 \u0644\u0627 \u0623\u0632\u0645\u0629 \u0641\u064a\u0647.\n\n\u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u0644\u064a\u0633\u062a \u0627\u0644\u0643\u0641\u0627\u0621\u0629. \u0627\u0644\u0645\u0634\u0643\u0644\u0629 \u0623\u0646 \u0627\u0644\u0645\u0643\u062a\u0628 \u0628\u0623\u0643\u0645\u0644\u0647 \u2014 \u0662\u0660 \u0634\u0631\u0643\u0629 \u0639\u0645\u064a\u0644\u060c \u0664\u0660 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644\u060c \u0661\u0665 \u062a\u0623\u0634\u064a\u0631\u0629 \u0625\u0642\u0627\u0645\u0629\u060c \u0668 \u0645\u0644\u0641\u0627\u062a \u062a\u0633\u062c\u064a\u0644 \u062c\u0627\u0631\u064a\u0629 \u2014 \u064a\u0639\u062a\u0645\u062f \u0639\u0644\u0649 \u0634\u062e\u0635 \u0648\u0627\u062d\u062f \u0644\u0627 \u064a\u0633\u062a\u0637\u064a\u0639 \u0627\u0644\u063a\u064a\u0627\u0628 \u064a\u0648\u0645\u0627\u064b \u0648\u0627\u062d\u062f\u0627\u064b.\n\nSmartPRO Hub \u0628\u064f\u0646\u064a\u062a \u0644\u0647\u0630\u0627 \u062a\u062d\u062f\u064a\u062f\u0627\u064b: \u0643\u0644 \u0645\u0644\u0641 \u0639\u0645\u064a\u0644 \u0641\u064a \u0645\u0643\u0627\u0646\u0647\u060c \u0648\u062a\u0646\u0628\u064a\u0647 \u062a\u0644\u0642\u0627\u0626\u064a \u0642\u0628\u0644 \u0627\u0646\u062a\u0647\u0627\u0621 \u0643\u0644 \u062a\u0635\u0631\u064a\u062d \u0639\u0645\u0644 \u0623\u0648 \u062a\u0623\u0634\u064a\u0631\u0629\u060c \u0648\u0643\u0644 \u0641\u0627\u062a\u0648\u0631\u0629 \u0645\u0631\u062a\u0628\u0637\u0629 \u0628\u0627\u0644\u062e\u062f\u0645\u0629 \u0627\u0644\u0645\u0646\u062c\u0632\u0629. \u0627\u0644\u0645\u0643\u062a\u0628 \u064a\u0639\u0645\u0644 \u2014 \u0633\u0648\u0627\u0621 \u0643\u0646\u062a \u062d\u0627\u0636\u0631\u0627\u064b \u0623\u0645 \u0644\u0627.\n\n\u062c\u0631\u0651\u0628 \u0645\u0633\u0627\u0639\u062f \u0633\u0646\u062f \u0627\u0644\u0630\u0643\u064a \u0645\u062c\u0627\u0646\u0627\u064b \u2014 \u0625\u062c\u0627\u0628\u0627\u062a \u0641\u0648\u0631\u064a\u0629 \u0639\u0646 \u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644 \u0648\u062a\u0623\u0634\u064a\u0631\u0627\u062a \u0627\u0644\u0625\u0642\u0627\u0645\u0629 \u0648\u0627\u0644\u0631\u0633\u0648\u0645 \u